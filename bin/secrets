#!/usr/bin/python3

"""
Manage secrets stored in ~/.secrets/.
- Show existing secret entries (tokens are never displayed)
- Show known services from secrets_manager.toml
- Add/update a secret via guided prompts

Storage format:
  ~/.secrets/<service>.toml with [[instance]] blocks
"""

