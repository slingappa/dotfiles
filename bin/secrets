    if data is None:
        return _filter_known_services(fallback)

    eps = data.get("known_service", [])
    if not isinstance(eps, list):
        if KNOWN_SERVICES_PATH_EXPLICIT:
            return []
        return _filter_known_services(fallback)

    loaded: list[KnownService] = []
    for raw in eps:
        if not isinstance(raw, dict):
            continue
        allowed = {"service", "api_url", "web_url", "name", "instructions", "validate", "expires", "generate"}
        unknown = set(raw.keys()) - allowed
        if unknown:
            # Keep strict: ignore entries with unexpected fields.
            continue
        service = str(raw.get("service") or "").strip()
        api_url = str(raw.get("api_url") or "").strip()
        name = str(raw.get("name") or "").strip() or service
        web_url = raw.get("web_url")
        web_url = str(web_url).strip() if isinstance(web_url, str) and web_url.strip() else None
        if not service or not api_url:
            continue
        instructions = raw.get("instructions") or []
        if isinstance(instructions, str):
            instructions = [instructions]
        if not isinstance(instructions, list):
            instructions = []
        instructions = [str(x) for x in instructions if str(x).strip()]
        validate_cfg = raw.get("validate")
        if validate_cfg is not None and not isinstance(validate_cfg, dict):
            validate_cfg = None

        # Back-compat: if validate was a list of request-like rules (legacy), wrap it.
        if validate_cfg is None:
            legacy_validate = raw.get("validate")
            if isinstance(legacy_validate, list) and all(isinstance(v, dict) for v in legacy_validate):
                validate_cfg = {"mode": "rest", "requests": legacy_validate}

        expires_cfg = raw.get("expires")
        if expires_cfg is not None and not isinstance(expires_cfg, dict):
            expires_cfg = None

        generate_cfg = raw.get("generate")
        if generate_cfg is not None and not isinstance(generate_cfg, dict):
            generate_cfg = None

        loaded.append(
            KnownService(
                service=service,
                api_url=api_url,
                name=name,
                web_url=web_url,
                instructions=instructions,
                validate=validate_cfg,
                expires=expires_cfg,
                generate=generate_cfg,
            )
        )
    if KNOWN_SERVICES_PATH_EXPLICIT:
        return _filter_known_services(loaded)
    return _filter_known_services(loaded or fallback)


METADATA_KV_RE = re.compile(r"^([A-Za-z0-9_.-]+)=(.+)$")
# Migration helper for legacy ~/.PAT/<service>.PAT lines.
PAT_LINE_RE = re.compile(r"^\s*(\S+)\s+:\s+(\S+)(?:\s+#\s*(.+))?\s*$")


def _parse_metadata_kv(meta_str: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    meta_str = (meta_str or "").strip()
    if not meta_str:
        return fields
    try:
        tokens = shlex.split(meta_str)
    except ValueError:
        tokens = meta_str.split()
    for token in tokens:
        kv = METADATA_KV_RE.match(token)
        if not kv:
            continue
        fields[kv.group(1)] = kv.group(2)
    return fields


def ensure_secrets_dir() -> None:
    SECRETS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(SECRETS_DIR, 0o700)


def _toml_quote(value: str) -> str:
    return json.dumps(value, ensure_ascii=False)


def _load_service_toml(path: Path) -> list[dict]:
    if not path.exists():
        return []
    try:
        raw = tomllib.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return []
    # Current format: [[secret]] — array of tables
    data = raw.get("secret")
    if isinstance(data, list):
        return [dict(item) for item in data if isinstance(item, dict)]
    # Legacy format: ["<name>"] — top-level dict of dicts
    out: list[dict] = []
    for key, item in raw.items():
        if isinstance(item, dict):
            entry = dict(item)
            entry["name"] = key
            out.append(entry)
    if out:
        return out
    # Older legacy: [instance.<name>]
    inst = raw.get("instance")
    if isinstance(inst, dict):
        for name, item in inst.items():
            if isinstance(item, dict):
                entry = dict(item)
                entry["name"] = name
                out.append(entry)
        return out
    # Oldest: [[instance]]
    if isinstance(inst, list):
        return [dict(item) for item in inst if isinstance(item, dict)]
    return []


_FIXED_KEYS = ("api_url", "secret", "auth")


def _write_service_toml(path: Path, instances: list[dict]) -> None:
    lines: list[str] = []
    for inst in instances:
        name = str(inst.get("name") or "").strip()
        if not name:
            continue
        lines.append("[[secret]]")
        # Write name first, then fixed keys, then any extra metadata keys.
        all_keys = ["name"] + list(_FIXED_KEYS) + [
            k for k in inst if k not in _FIXED_KEYS and k not in ("name", "url")
        ]
        for key in all_keys:
            if key not in inst or inst.get(key) in (None, "") or (key == "default" and not inst.get(key)):
                continue
            val = inst.get(key)
            if isinstance(val, bool):
                lines.append(f"{key} = {'true' if val else 'false'}")
            elif isinstance(val, int):
                lines.append(f"{key} = {val}")
            else:
                lines.append(f"{key} = {_toml_quote(str(val))}")
        lines.append("")
    text = "\n".join(lines).rstrip() + ("\n" if lines else "")
    path.write_text(text, encoding="utf-8")
    os.chmod(path, 0o600)


def load_secret_entries() -> list[SecretEntry]:
    entries: list[SecretEntry] = []
    if not SECRETS_DIR.exists():
        return entries
    known_by_key = _known_service_by_key()
    for path in sorted(SECRETS_DIR.glob("*.toml")):
        service = path.stem
        if not _include_service_name(service):
            continue
        instances = _load_service_toml(path)
        changed = False
        for inst in instances:
            api_url = str(inst.get("api_url") or inst.get("url") or "").strip()
            name = str(inst.get("name") or "").strip()
            if not name:
                continue
            secret_raw = inst.get("secret") or inst.get("token")
            secret = str(secret_raw).strip() if isinstance(secret_raw, str) and str(secret_raw).strip() else None
            raw_auth = inst.get("auth")
            auth = _normalize_auth_value(raw_auth, service, api_url, known_by_key)
            if isinstance(raw_auth, str) and auth and raw_auth.strip() != auth:
                inst["auth"] = auth
                changed = True
            meta: dict = {}
            for key, val in inst.items():
                if key in ("name", "api_url", "url", "secret", "token", "auth", "default"):
                    continue
                if val is None or (isinstance(val, str) and not val.strip()):
                    continue
                meta[key] = str(val).strip() if not isinstance(val, int) else val
            is_default = bool(inst.get("default", False))
            entries.append(
                SecretEntry(
                    service=service,
                    api_url=api_url,
                    name=name,
                    secret=secret,
                    auth=auth,
                    meta=meta,
                    default=is_default,
                )
            )
        if changed:
            _write_service_toml(path, instances)
    return entries


def _read_existing_token(service: str, name: str) -> str | None:
    """Return secret for service+name from ~/.secrets without exposing it in UI."""
    path = SECRETS_DIR / f"{service}.toml"
    for inst in _load_service_toml(path):
        if str(inst.get("name") or "").strip() != name:
            continue
        val = inst.get("secret") or inst.get("token")
        if isinstance(val, str) and val.strip():
            return val.strip()
    return None


def _inst_api_url(inst: dict) -> str:
    return str(inst.get("api_url") or inst.get("url") or "").strip()


def _check_defaults(instances: list[dict]) -> list[str]:
    """Return error messages for any api_url cluster that lacks exactly one default."""
    from collections import defaultdict
    clusters: dict[str, list[dict]] = defaultdict(list)
    for inst in instances:
        clusters[_inst_api_url(inst)].append(inst)
    errors = []
    for url, group in clusters.items():
        if not url:
            continue
        defaults = [i for i in group if i.get("default")]
        names = [str(i.get("name") or "") for i in group]
        if len(defaults) == 0:
            errors.append(
                f"No default set for api_url={url!r} "
                f"(entries: {', '.join(names)}). "
                f"Mark one as default."
            )
        elif len(defaults) > 1:
            dnames = [str(i.get("name") or "") for i in defaults]
            errors.append(
                f"Multiple defaults for api_url={url!r}: {', '.join(dnames)}. "
                f"Only one entry per URL may be the default."
            )
    return errors


def _fix_defaults(service: str) -> None:
    """Ensure every api_url cluster in a service file has exactly one default.

    Silently fixes missing or duplicate defaults by picking the first entry
    in each cluster. Does nothing if the file doesn't exist or is already valid.
    """
    from collections import defaultdict
    path = SECRETS_DIR / f"{service}.toml"
    instances = _load_service_toml(path)
    if not instances:
        return
    clusters: dict[str, list[int]] = defaultdict(list)
    for i, inst in enumerate(instances):
        url = _inst_api_url(inst)
        if url:
            clusters[url].append(i)
    changed = False
    for url, idxs in clusters.items():
        defaults = [i for i in idxs if instances[i].get("default")]
        if len(defaults) == 1:
            continue  # already correct
        # Clear all defaults for this cluster, then set the first entry
        for i in idxs:
            if instances[i].get("default"):
                instances[i]["default"] = False
                changed = True
        instances[idxs[0]]["default"] = True
        changed = True
    if changed:
        _write_service_toml(path, instances)


def update_secret_file(
    service: str,
    api_url: str,
    name: str,
    secret: str,
    fields: dict[str, object] | None,
    original_name: str | None = None,
    default: bool = False,
) -> None:
    ensure_secrets_dir()
    path = SECRETS_DIR / f"{service}.toml"
    instances = _load_service_toml(path)
    lookup_name = original_name.strip() if original_name else name

    # Duplicate-name check: name must be unique within the service file.
    for inst in instances:
        inst_name = str(inst.get("name") or "").strip()
        if inst_name == name and inst_name != lookup_name:
            raise ValueError(f"Name {name!r} is already in use. Choose a different name.")

    base: dict[str, object] = {"name": name, "api_url": api_url, "secret": secret, "default": default}
    if fields:
        for key, val in fields.items():
            if key in ("name", "api_url", "url", "secret", "token") or val in (None, ""):
                continue
            if key == "expires_epoch" and isinstance(val, str) and val.strip().lstrip("-").isdigit():
                base[key] = int(val.strip())
            else:
                base[key] = val

    # Apply the update/insert
    updated = False
    old_api_url: str | None = None
    for i, inst in enumerate(instances):
        if str(inst.get("name") or "").strip() == lookup_name:
            old_api_url = _inst_api_url(inst)
            instances[i] = base
            updated = True
            break
    if not updated:
        instances.append(base)

    # Auto-assign default if this is the only entry for its api_url
    if api_url:
        same_url = [i for i in instances if _inst_api_url(i) == api_url]
        if len(same_url) == 1:
            base["default"] = True

    # If this entry is the default, clear default on other entries with the same api_url
    if base.get("default"):
        for inst in instances:
            if str(inst.get("name") or "").strip() != name and _inst_api_url(inst) == api_url:
                inst["default"] = False

    # Validate: every non-empty api_url cluster must have exactly one default
    errors = _check_defaults(instances)

    # If api_url changed, the old cluster may now lack a default — give a helpful hint
    if old_api_url and old_api_url != api_url:
        old_cluster = [i for i in instances if _inst_api_url(i) == old_api_url]
        if old_cluster and not any(i.get("default") for i in old_cluster):
            old_names = [str(i.get("name") or "") for i in old_cluster]
            errors.append(
                f"Changing the URL left api_url={old_api_url!r} without a default "
                f"(remaining entries: {', '.join(old_names)}). "
                f"Edit one of those entries and mark it as default first."
            )

    if errors:
        raise ValueError("\n".join(errors))

    _write_service_toml(path, instances)


def delete_secret_entry(service: str, name: str) -> bool:
    """Delete a named entry from a service TOML file. Returns True if deleted.

    Raises ValueError if deletion would leave an api_url cluster without a default.
    """
    path = SECRETS_DIR / f"{service}.toml"
    instances = _load_service_toml(path)
    new_instances = [i for i in instances if str(i.get("name") or "").strip() != name]
    if len(new_instances) == len(instances):
        return False
    errors = _check_defaults(new_instances)
    if errors:
        raise ValueError("\n".join(errors))
    _write_service_toml(path, new_instances)
    return True


def migrate_pat_dir(pat_dir: Path, secrets_dir: Path) -> None:
    if not pat_dir.exists() or secrets_dir.exists():
        return
    secrets_dir.mkdir(parents=True, exist_ok=True)
    os.chmod(secrets_dir, 0o700)
    known_by_key = _known_service_by_key()
    for path in sorted(pat_dir.glob("*.PAT")):
        service = path.stem
        try:
            lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        except OSError:
            continue
        instances: list[dict] = []
        default_urls: set[str] = set()
        count = 0
        for line in lines:
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            m = PAT_LINE_RE.match(s)
            if not m:
                continue
            count += 1
            url = m.group(1).strip()
            token = m.group(2).strip()
            meta = _parse_metadata_kv(m.group(3) or "")
            name = (meta.get("name") or "").strip() or f"{service}-{count}"
            inst: dict[str, object] = {"name": name, "api_url": url, "secret": token}
            if url and url not in default_urls:
                inst["default"] = True
                default_urls.add(url)
            auth = _normalize_auth_value(meta.get("auth"), service, url, known_by_key) or "bearer"
            inst["auth"] = auth
            for key in ("web_url", "email", "expires"):
                if key in meta and str(meta[key]).strip():
                    inst[key] = str(meta[key]).strip()
            exp = (meta.get("expires_epoch") or "").strip()
            if exp.isdigit():
                inst["expires_epoch"] = int(exp)
            instances.append(inst)
        if instances:
            out = secrets_dir / f"{service}.toml"
            _write_service_toml(out, instances)


def _http_get_status(url: str, headers: dict[str, str], timeout_s: float = 8.0) -> tuple[int | None, str | None]:
    req = urllib.request.Request(url, headers=headers, method="GET")
    ctx = ssl._create_unverified_context()
    try:
        with urllib.request.urlopen(req, timeout=timeout_s, context=ctx) as resp:
            return resp.getcode(), None
    except urllib.error.HTTPError as e:
        return e.code, None
    except Exception as e:
        return None, str(e)


def _http_request_status(
    url: str,
    *,
    method: str,
    headers: dict[str, str],
    timeout_s: float = 8.0,
) -> tuple[int | None, str | None]:
    req = urllib.request.Request(url, headers=headers, method=method.upper())
    ctx = ssl._create_unverified_context()
    try:
        with urllib.request.urlopen(req, timeout=timeout_s, context=ctx) as resp:
            return resp.getcode(), None
    except urllib.error.HTTPError as e:
        return e.code, None
    except Exception as e:
        return None, str(e)


def _http_get_json(url: str, headers: dict[str, str], timeout_s: float = 8.0) -> tuple[object | None, int | None, str | None]:
    req = urllib.request.Request(url, headers=headers, method="GET")
    ctx = ssl._create_unverified_context()
    try:
        with urllib.request.urlopen(req, timeout=timeout_s, context=ctx) as resp:
            code = resp.getcode()
            data = resp.read()
        try:
            return json.loads(data.decode("utf-8", errors="replace")), code, None
        except Exception as e:
            return None, code, f"JSON decode error: {e}"
    except urllib.error.HTTPError as e:
        return None, e.code, None
    except Exception as e:
        return None, None, str(e)


def _http_request_json(
    url: str,
    *,
    method: str,
    headers: dict[str, str],
    body_obj: object | None,
    timeout_s: float = 12.0,
) -> tuple[object | None, int | None, str | None]:
    data: bytes | None = None
    if body_obj is not None:
        try:
            data = json.dumps(body_obj).encode("utf-8")
        except Exception as e:
            return None, None, f"JSON encode error: {e}"
    req = urllib.request.Request(url, data=data, headers=headers, method=method.upper())
    ctx = ssl._create_unverified_context()
    try:
        with urllib.request.urlopen(req, timeout=timeout_s, context=ctx) as resp:
            code = resp.getcode()
            payload = resp.read()
        if not payload:
            return None, code, None
        try:
            return json.loads(payload.decode("utf-8", errors="replace")), code, None
        except Exception as e:
            return None, code, f"JSON decode error: {e}"
    except urllib.error.HTTPError as e:
        try:
            body = e.read()
            if body:
                # Helpful for debugging, but don't surface secrets.
                _ = body
        except Exception:
            pass
        return None, e.code, None
    except Exception as e:
        return None, None, str(e)


def _interpolate_header_value(template: str, token: str, email: str | None) -> tuple[str | None, str | None]:
    """Return interpolated header value or (None, error)."""
    if "{basic_b64}" in template:
        mail = (email or "").strip()
        if not mail:
            return None, "missing required metadata email=... for basic_b64"
        userpass = f"{mail}:{token}".encode("utf-8")
        basic_b64 = base64.b64encode(userpass).decode("ascii")
        template = template.replace("{basic_b64}", basic_b64)
    return template.replace("{token}", token), None


def _b64url_decode(data: str) -> bytes:
    pad = "=" * (-len(data) % 4)
    return base64.urlsafe_b64decode((data + pad).encode("ascii"))


def _decode_jwt_payload(token: str) -> tuple[dict | None, str | None]:
    parts = token.split(".")
    if len(parts) < 2:
        return None, "not a JWT (missing '.')"
    try:
        payload_raw = _b64url_decode(parts[1]).decode("utf-8", errors="strict")
        payload = json.loads(payload_raw)
        if not isinstance(payload, dict):
            return None, "JWT payload is not an object"
        return payload, None
    except Exception as e:
        return None, f"JWT decode error: {e}"


def _json_field_lookup(obj: object, field: str) -> tuple[bool, object | None]:
    cur: object = obj
    for part in [p for p in field.split(".") if p]:
        if not isinstance(cur, dict):
            return False, None
        if part not in cur:
            return False, None
        cur = cur[part]
    return True, cur


def _json_field_get(obj: object, field: str) -> object | None:
    _, value = _json_field_lookup(obj, field)
    return value


def _parse_iso8601_epoch(value: object) -> int | None:
    if value in (None, ""):
        return None
    if isinstance(value, (int, float)):
        return int(value)
    s = str(value).strip()
    if not s:
        return None
    if s.lstrip("-").isdigit():
        try:
            return int(s)
        except Exception:
            return None
    try:
        dt = datetime.fromisoformat(s.replace("Z", "+00:00"))
    except Exception:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return int(dt.timestamp())


def _http_json_select(obj: object, cfg: dict[str, object] | None) -> tuple[object | None, str | None]:
    if not isinstance(cfg, dict) or not cfg:
        return obj, None

    strategy = str(cfg.get("strategy") or "").strip().lower()
    if not strategy:
        return obj, None

    if strategy == "single":
        if not isinstance(obj, list):
            return None, "expires selector single requires a JSON list"
        if len(obj) != 1:
            return None, None
        return obj[0], None

    if strategy == "max_field":
        if not isinstance(obj, list):
            return None, "expires selector max_field requires a JSON list"
        field = str(cfg.get("field") or "").strip()
        if not field:
            return None, "expires selector max_field missing field"
        max_items: list[tuple[int, object]] = []
        best_epoch: int | None = None
        for item in obj:
            exists, raw = _json_field_lookup(item, field)
            if not exists:
                continue
            epoch = _parse_iso8601_epoch(raw)
            if epoch is None:
                continue
            if best_epoch is None or epoch > best_epoch:
                best_epoch = epoch
                max_items = [(epoch, item)]
            elif epoch == best_epoch:
                max_items.append((epoch, item))
        if best_epoch is None:
            return None, None
        if len(max_items) != 1:
            return None, "expires selector max_field is ambiguous"
        max_age_s = cfg.get("max_age_s")
        if max_age_s not in (None, ""):
            try:
                max_age_i = int(max_age_s)
            except Exception:
                max_age_i = 0
            age_s = int(datetime.now(timezone.utc).timestamp()) - best_epoch
            if max_age_i > 0 and age_s > max_age_i:
                return None, None
        return max_items[0][1], None

    return None, f"Unknown expires selector strategy: {strategy}"


def _make_url(base: str, path: str) -> str:
    """Build an absolute URL from (base, path).

    Supports TOML configs that provide a full URL in place of a path.
    """
    p = (path or "").strip()
    if p.startswith("http://") or p.startswith("https://"):
        return p
    if not p.startswith("/"):
        p = "/" + p
    return base.rstrip("/") + p


def _interpolate_generate_value(template: str, username: str, password: str) -> tuple[str, str | None]:
    """Interpolate generation templates using interactive basic-auth creds."""
    out = template
    if "{basic_b64}" in out:
        userpass = f"{username}:{password}".encode("utf-8")
        basic_b64 = base64.b64encode(userpass).decode("ascii")
        out = out.replace("{basic_b64}", basic_b64)
    if "{epoch}" in out:
        out = out.replace("{epoch}", str(int(datetime.now(timezone.utc).timestamp())))
    out = out.replace("{user}", username).replace("{pass}", password)
    return out, None


def _interpolate_generate_obj(obj: object, username: str, password: str) -> object:
    if isinstance(obj, dict):
        return {str(k): _interpolate_generate_obj(v, username, password) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_interpolate_generate_obj(v, username, password) for v in obj]
    if isinstance(obj, str):
        s, _ = _interpolate_generate_value(obj, username, password)
        return s
    return obj


def _generate_token_known(known_service: "KnownService", username: str, password: str) -> tuple[str | None, str]:
    """Generate a new token using only generation rules from TOML (KnownService.generate)."""
    cfg = known_service.generate or {}
    if not isinstance(cfg, dict) or not cfg:
        return None, "No token generator configured for this service."

    mode = str(cfg.get("mode") or "").strip().lower()
    # Back-compat: legacy generator used type=http_json
    if not mode and str(cfg.get("type") or "").strip().lower() == "http_json":
        mode = "rest"
    if not mode:
        mode = "rest"

    if mode == "shell":
        cmd = str(cfg.get("command") or "").strip()
        if not cmd:
            return None, "shell generator missing command=..."
        timeout_s = cfg.get("timeout_s") or 30
        try:
            timeout_s = float(timeout_s)
        except Exception:
            timeout_s = 30.0

        env = os.environ.copy()
        env["PAT_USERNAME"] = username
        env["PAT_PASSWORD"] = password
        env["PAT_BASIC_B64"] = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        env["PAT_SERVICE"] = known_service.service
        env["PAT_API_URL"] = known_service.api_url
        if known_service.web_url:
            env["PAT_WEB_URL"] = known_service.web_url

        try:
            proc = subprocess.run(
                ["bash", "-lc", cmd],
                env=env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                timeout=timeout_s,
            )
        except subprocess.TimeoutExpired:
            return None, f"shell generator timed out after {timeout_s:.0f}s"
        if proc.returncode != 0:
            out = (proc.stdout or "").strip()
            err = (proc.stderr or "").strip()
            first = (out.splitlines() or err.splitlines() or [""])[0].strip()
            if first.upper().startswith("HTTP "):
                return None, f"{known_service.api_url} -> {first}"
            return None, f"shell generator failed (exit {proc.returncode})"
        token_out = ""
        for line in (proc.stdout or "").splitlines():
            if line.strip():
                token_out = line.strip()
                break
        if not token_out:
            return None, "shell generator produced no token on stdout"
        return token_out, "Generated token via shell"

    if mode != "rest":
        return None, f"Unsupported generator mode: {mode}"

    path = str(cfg.get("path") or "").strip()
    token_field = str(cfg.get("token_field") or "token").strip() or "token"
    method = str(cfg.get("method") or "POST").strip() or "POST"
    headers = cfg.get("headers") or {}
    body_obj = cfg.get("json")
    ok = cfg.get("ok") or [200]
    if isinstance(ok, int):
        ok = [ok]
    if not isinstance(ok, list):
        ok = [200]
    ok_set = {int(x) for x in ok if str(x).isdigit()}

    if not path or not isinstance(headers, dict):
        return None, "rest generator missing path/headers"

    hdrs: dict[str, str] = {}
    for hk, hv in headers.items():
        key = str(hk).strip()
        val_t = str(hv)
        val, _ = _interpolate_generate_value(val_t, username, password)
        if key:
            hdrs[key] = val

    if body_obj is not None:
        body_obj = _interpolate_generate_obj(body_obj, username, password)

    url = _make_url(known_service.api_url, path)
    obj, code, err = _http_request_json(url, method=method, headers=hdrs, body_obj=body_obj)
    if code is None:
        return None, err or "request failed"
    if code not in ok_set:
        return None, f"{url} -> HTTP {code}"
    if obj is None:
        return None, f"{url} -> no JSON body"
    token = _json_field_get(obj, token_field)
    if not isinstance(token, str) or not token.strip():
        # Make generation resilient across a few common response schemas
        # without expanding the TOML schema.
        for alt in ("token", "rawToken", "raw_token"):
            if alt == token_field:
                continue
            alt_val = _json_field_get(obj, alt)
            if isinstance(alt_val, str) and alt_val.strip():
                token = alt_val
                break
    if not isinstance(token, str) or not token.strip():
        return None, f"response missing token field: {token_field}"
    return token.strip(), f"Generated token via {url}"


def _expires_metadata_from_known(known_service: "KnownService", token: str) -> tuple[dict[str, object], str | None]:
    """Return expiry fields derived from known service config, or ({}, None) if not available."""
    cfg = known_service.expires or {}
    if not isinstance(cfg, dict) or not cfg:
        return {}, None

    t = str(cfg.get("type") or "").strip().lower()
    if not t:
        return {}, None

    if t == "jwt":
        claim = str(cfg.get("claim") or "exp").strip() or "exp"
        payload, err = _decode_jwt_payload(token)
        if err:
            return {}, err
        exp = payload.get(claim)
        try:
            exp_i = int(exp)
        except Exception:
            return {}, f"JWT missing/invalid {claim} claim"
        return {"expires_epoch": exp_i}, None

    if t == "http_json":
        probe_cfg = cfg.get("probe")
        path = str(cfg.get("path") or "").strip()
        field = str(cfg.get("field") or "").strip()
        value_type = str(cfg.get("value_type") or "").strip().lower() or "date"
        headers = cfg.get("headers") or {}
        select_cfg = cfg.get("select")
        ok = cfg.get("ok") or [200]
        if isinstance(ok, int):
            ok = [ok]
        if not isinstance(ok, list):
            ok = [200]
        ok_set = {int(x) for x in ok if str(x).isdigit()}
        if not path or not field or not isinstance(headers, dict):
            return {}, "expires http_json config missing path/field/headers"

        if isinstance(probe_cfg, dict) and probe_cfg:
            probe_path = str(probe_cfg.get("path") or "").strip()
            probe_headers_cfg = probe_cfg.get("headers") or {}
            probe_method = str(probe_cfg.get("method") or "GET").strip() or "GET"
            probe_ok = probe_cfg.get("ok") or [200]
            if isinstance(probe_ok, int):
                probe_ok = [probe_ok]
            if not isinstance(probe_ok, list):
                probe_ok = [200]
            probe_ok_set = {int(x) for x in probe_ok if str(x).isdigit()}
            if not probe_path or not isinstance(probe_headers_cfg, dict):
                return {}, "expires probe config missing path/headers"
            probe_headers: dict[str, str] = {}
            for hk, hv in probe_headers_cfg.items():
                key = str(hk).strip()
                val_t = str(hv)
                val, err = _interpolate_header_value(val_t, token, None)
                if err:
                    return {}, err
                if key:
                    probe_headers[key] = val or ""
            probe_url = _make_url(known_service.api_url, probe_path)
            _, probe_code, probe_err = _http_request_json(probe_url, method=probe_method, headers=probe_headers, body_obj=None)
            if probe_code is None:
                return {}, probe_err or "expires probe request failed"
            if probe_code not in probe_ok_set:
                return {}, f"{probe_url} -> HTTP {probe_code}"

        url = _make_url(known_service.api_url, path)
        hdrs: dict[str, str] = {}
        for hk, hv in headers.items():
            key = str(hk).strip()
            val_t = str(hv)
            val, err = _interpolate_header_value(val_t, token, None)
            if err:
                return {}, err
            if key:
                hdrs[key] = val or ""

        obj, code, err = _http_get_json(url, hdrs)
        if code is not None and code not in ok_set:
            return {}, f"{url} -> HTTP {code}"
        if obj is None:
            return {}, err or f"{url} -> no JSON body"

        obj, select_err = _http_json_select(obj, select_cfg if isinstance(select_cfg, dict) else None)
        if select_err:
            return {}, select_err
        if obj is None:
            return {}, None
        exists, raw = _json_field_lookup(obj, field)
        if not exists:
            return {}, None

        never_values_cfg = cfg.get("never_values") or []
        if isinstance(never_values_cfg, (str, int, float)):
            never_values_cfg = [never_values_cfg]
        never_values = {str(v).strip() for v in never_values_cfg if str(v).strip()}
        if raw is None:
            if bool(cfg.get("null_means_never")):
                return {"expires": "never"}, None
            return {}, None
        raw_s = str(raw).strip()
        if raw_s == "":
            return {}, None
        if raw_s in never_values:
            return {"expires": "never"}, None

        if value_type == "epoch":
            try:
                return {"expires_epoch": int(raw)}, None
            except Exception:
                return {}, f"expires field {field} not an epoch int"
        if value_type in {"iso8601", "datetime"}:
            epoch = _parse_iso8601_epoch(raw)
            if epoch is None:
                return {}, f"expires field {field} not an ISO-8601 datetime"
            return {"expires_epoch": epoch}, None
        return {"expires": raw_s}, None

    return {}, f"Unknown expires type: {t}"


def _default_auth_for_known(known_service: "KnownService") -> str:
    # Prefer deriving from validate REST headers, fall back to service defaults.
    cfg = known_service.validate or {}
    if isinstance(cfg, dict) and str(cfg.get("mode") or "").strip().lower() in {"", "rest"}:
        reqs = cfg.get("requests") or []
        if isinstance(reqs, dict):
            reqs = [reqs]
        if isinstance(reqs, list):
            for req in reqs:
                if not isinstance(req, dict):
                    continue
                headers = req.get("headers") or {}
                if not isinstance(headers, dict):
                    continue
                for hk, hv in headers.items():
                    key = str(hk).strip().upper()
                    val = str(hv)
                    if key == "PRIVATE-TOKEN":
                        return "private-token"
                    if key == "AUTHORIZATION" and val.strip().lower().startswith("basic "):
                        return "basic"
                    if key == "AUTHORIZATION" and "bearer" in val.lower():
                        return "bearer"

    service = known_service.service.strip().lower()
    if service == "gitlab":
        return "private-token"
    if service == "confluence":
        return "basic"
    return "bearer"


def _default_fields_for_known(known_service: "KnownService") -> dict[str, object]:
    fields: dict[str, object] = {"auth": _default_auth_for_known(known_service)}
    if known_service.web_url:
        fields["web_url"] = known_service.web_url
    return fields


def _validate_token_known(known_service: "KnownService", token: str, fields: dict[str, str]) -> tuple[bool, str]:
    """Validate token using only TOML config.

    The TOML must specify one of two modes:
    - validate.mode = "rest": perform one or more REST requests
    - validate.mode = "shell": run a shell command
    """
    cfg = known_service.validate or {}
    if not isinstance(cfg, dict) or not cfg:
        return True, "No validation configured; skipping."

    mode = str(cfg.get("mode") or "rest").strip().lower()

    if mode == "shell":
        cmd = str(cfg.get("command") or "").strip()
        if not cmd:
            return False, "shell validator missing command=..."
        timeout_s = cfg.get("timeout_s") or 30
        try:
            timeout_s = float(timeout_s)
        except Exception:
            timeout_s = 30.0

        env = os.environ.copy()
        env["PAT_TOKEN"] = token
        env["PAT_SERVICE"] = known_service.service
        env["PAT_API_URL"] = known_service.api_url
        if known_service.web_url:
            env["PAT_WEB_URL"] = known_service.web_url
        for k, v in (fields or {}).items():
            safe = re.sub(r"[^A-Za-z0-9_]", "_", str(k)).upper()
            env[f"PAT_META_{safe}"] = str(v)

        try:
            proc = subprocess.run(
                ["bash", "-lc", cmd],
                env=env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                timeout=timeout_s,
            )
        except subprocess.TimeoutExpired:
            return False, f"shell validator timed out after {timeout_s:.0f}s"

        if proc.returncode == 0:
            return True, "OK"

        # For UX, allow the command to output a simple status line like "HTTP 401".
        out = (proc.stdout or "").strip()
        err = (proc.stderr or "").strip()
        first = (out.splitlines() or err.splitlines() or [""])[0].strip()
        if first.upper().startswith("HTTP "):
            return False, f"{known_service.api_url} -> {first}"
        return False, f"shell validator failed (exit {proc.returncode})"

    if mode != "rest":
        return False, f"Unsupported validator mode: {mode}"

    api_url = known_service.api_url.rstrip("/")
    reqs = cfg.get("requests") or []
    if isinstance(reqs, dict):
        reqs = [reqs]
    if not isinstance(reqs, list) or not reqs:
        return False, "rest validator missing requests=[...]"

    last_msg = "No requests executed"
    for req in reqs:
        if not isinstance(req, dict):
            continue
        method = str(req.get("method") or "GET").strip() or "GET"
        path = str(req.get("path") or "").strip()
        if not path:
            continue
        ok = req.get("ok") or [200]
        if isinstance(ok, int):
            ok = [ok]
        if not isinstance(ok, list):
            ok = [200]
        ok_set = {int(x) for x in ok if str(x).isdigit()}
        headers = req.get("headers") or {}
        if not isinstance(headers, dict):
            headers = {}

        requires = req.get("requires") or []
        if isinstance(requires, str):
            requires = [requires]
        if isinstance(requires, list):
            for key in requires:
                k = str(key).strip()
                if k and not (fields.get(k) or "").strip():
                    return False, f"Missing required metadata: {k}"

        url = _make_url(api_url, path)
        hdrs: dict[str, str] = {}
        for hk, hv in headers.items():
            key = str(hk).strip()
            val_t = str(hv)
            val, err = _interpolate_header_value(val_t, token, fields.get("email"))
            if err:
                return False, err
            if key:
                hdrs[key] = val or ""

        code, err = _http_request_status(url, method=method, headers=hdrs)
        if code is None:
            last_msg = f"{url} -> error: {err}"
            continue
        last_msg = f"{url} -> HTTP {code}"
        if code in ok_set:
            return True, last_msg

    return False, last_msg


def _format_path_for_ui(path: Path) -> str:
    try:
        home = Path.home().resolve()
        p = path.resolve()
        if str(p).startswith(str(home) + os.sep):
            return "~" + os.sep + str(p.relative_to(home))
    except Exception:
        pass
    return str(path)


def build_existing_index(entries: Iterable[SecretEntry]) -> dict[str, set[str]]:
    index: dict[str, set[str]] = {}
    for entry in entries:
        index.setdefault(entry.service, set()).add(entry.api_url)
    return index


def render_existing_table(console: Console, entries: list[SecretEntry]) -> None:
    table = Table(title="My Secrets", box=box.SIMPLE_HEAVY)
    table.add_column("Name", style="cyan", no_wrap=True)
    table.add_column("Service", style="white", no_wrap=True)
    table.add_column("URL", style="green")
    table.add_column("Expires", style="yellow")
    table.add_column("Auth", style="magenta", no_wrap=True)
    table.add_column("Details", style="magenta")

    if not entries:
        table.add_row("—", "—", "No secrets found", "—", "—", "—")
    else:
        for entry in sorted(entries, key=lambda e: (e.service.casefold(), (e.name or e.service).casefold())):
            auth = entry.auth or "unknown"
            expires = _format_expires(entry.meta.get("expires_epoch"), entry.meta.get("expires"))
            displayed_url = entry.meta.get("web_url") or entry.api_url or ""
            skip_cli = {"expires", "expires_epoch", "web_url"}
            info_parts = []
            for k, v in entry.meta.items():
                if k in skip_cli:
                    continue
                if k == "api_url" and v == displayed_url:
                    continue
                info_parts.append(f"{k}={v}")
            if entry.api_url and entry.api_url != displayed_url and "api_url" not in entry.meta:
                info_parts.insert(0, f"api_url={entry.api_url}")
            info = " ".join(info_parts) if info_parts else "—"
            url = displayed_url or "—"
            table.add_row(entry.name or entry.service, entry.service, url, expires, auth, info)

    console.print(table)


def render_missing_table(console: Console, missing: list[KnownService]) -> None:
    table = Table(title="Known Services", box=box.SIMPLE_HEAVY)
    table.add_column("Service", style="cyan", no_wrap=True)
    table.add_column("URL", style="green")

    if not missing:
        table.add_row("—", "No known services")
    else:
        for known_service in sorted(missing, key=lambda e: (e.service.casefold(), (e.name or e.service).casefold())):
            url = known_service.web_url or known_service.api_url
            service_display = known_service.name or known_service.service
            table.add_row(service_display, url)

    console.print(table)


def _region_in_scroll(widget, scroll) -> "Region | None":
    """Return widget's region translated into scroll's virtual coordinate space."""
    from textual.widget import Widget
    region = widget.virtual_region_with_margin
    node = widget
    while isinstance(node.parent, Widget) and node is not scroll:
        container = node.parent
        region = (
            region
            .translate(container.styles.margin.top_left)
            .translate(container.styles.border.spacing.top_left)
            .translate(container.virtual_region_with_margin.offset)
        )
        if node is scroll:
            break
        node = container
        if node is scroll:
            break
    return region


class FormScroll(VerticalScroll):
    """VerticalScroll that disables up/down key bindings so the modal handles field navigation."""

    can_focus = False

    def check_action(self, action: str, parameters: tuple) -> bool | None:
        if action in ("scroll_up", "scroll_down"):
            return False
        return super().check_action(action, parameters)


class RowEditModal(ModalScreen[str | None]):
    """Modal for editing a metadata row as a single 'key=value' string."""

    CSS = """
    RowEditModal {
        align: center middle;
    }
    #row_popup {
        width: 70%;
        max-width: 90;
        height: auto;
        padding: 1 2;
        border: round #00d75f;
        background: black;
    }
    #row_label {
        height: auto;
        color: #aaaaaa;
        margin-bottom: 1;
    }
    #row_error {
        height: auto;
        color: red;
        margin-top: 0;
    }
    Input {
        width: 100%;
        border: round #444444;
        padding: 0 1;
    }
    Input:focus {
        border: round cyan;
    }
    #row_hint {
        height: auto;
        color: #aaaaaa;
        margin-top: 1;
    }
    """

    BINDINGS = [
        ("escape", "cancel", "Cancel"),
    ]

    def __init__(self, value: str) -> None:
        super().__init__()
        self._initial = value

    def compose(self) -> ComposeResult:
        with Vertical(id="row_popup"):
            yield Static("Edit metadata entry (key=value)", id="row_label")
            yield Input(value=self._initial, id="row_input", placeholder="key=value")
            yield Static("", id="row_error")
            yield Static("Enter to save  •  Esc to cancel", id="row_hint")

    def on_mount(self) -> None:
        inp = self.query_one("#row_input", Input)
        inp.focus()
        inp.cursor_position = len(inp.value)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        raw = event.input.value.strip()
        if "=" not in raw:
            self.query_one("#row_error", Static).update("Must be in the form key=value")
            return
        key, _, val = raw.partition("=")
        if not key.strip():
            self.query_one("#row_error", Static).update("Key cannot be empty")
            return
        self.dismiss(raw)

    def action_cancel(self) -> None:
        self.dismiss(None)


class MetaTable(Widget):
    """Key-value metadata editor.

    Displays as a Rich table matching the main screen style.
    Up/down navigates rows.  Enter opens a modal to edit the row as key=value.
    Ctrl+N/+ adds a new row.  Ctrl+D/Delete removes the selected row.
    """

    can_focus = True
    can_focus_children = False

    DEFAULT_CSS = """
    MetaTable {
        height: auto;
        border: round #444444;
        background: transparent;
        padding: 0 0;
    }
    MetaTable:focus {
        border: round cyan;
    }
    """

    BINDINGS = [
        ("ctrl+n", "add_row", "Add row"),
        ("+", "add_row", "Add row"),
        ("ctrl+d", "delete_row", "Delete row"),
        ("delete", "delete_row", "Delete row"),
        ("enter", "edit_row", "Edit row"),
    ]

    def __init__(self, initial: dict[str, object] | None = None, **kwargs) -> None:
        super().__init__(**kwargs)
        self._rows: list[tuple[str, str]] = [
            (str(k), "" if v is None else str(v))
            for k, v in (initial or {}).items()
        ]
        if not self._rows:
            self._rows = [("", "")]
        self._cursor: int = 0
        self._has_focus: bool = False

    def _build_table(self) -> Table:
        tbl = Table(box=box.SIMPLE_HEAVY, show_header=True, expand=True)
        tbl.add_column("Metadata", style="cyan")
        for i, (k, v) in enumerate(self._rows):
            if k:
                entry = f"[cyan]{k}[/cyan]=[green]{v}[/green]"
            else:
                entry = "[dim](empty — press Enter to edit)[/dim]"
            style = "reverse" if i == self._cursor and self._has_focus else None
            tbl.add_row(entry, style=style)
        return tbl

    def compose(self) -> ComposeResult:
        yield Static(self._build_table(), id="meta_static")

    def _refresh_table(self) -> None:
        try:
            self.query_one("#meta_static", Static).update(self._build_table())
        except Exception:
            pass

    def on_focus(self, event) -> None:
        self._has_focus = True
        self._cursor = 0
        self._refresh_table()

    def on_blur(self, event) -> None:
        self._has_focus = False
        self._refresh_table()

    def on_key(self, event: events.Key) -> None:
        if event.key == "up":
            event.stop()
            if self._cursor == 0:
                self.app.screen.action_prev_field()
            else:
                self._cursor -= 1
                self._refresh_table()
        elif event.key == "down":
            event.stop()
            if self._cursor >= len(self._rows) - 1:
                self.app.screen.action_next_field()
            else:
                self._cursor += 1
                self._refresh_table()

    def action_edit_row(self) -> None:
        if not self._rows:
            return
        k, v = self._rows[self._cursor]
        prefill = f"{k}={v}" if k else ""
        self.app.push_screen(
            RowEditModal(value=prefill),
            self._on_row_edit,
        )

    def _on_row_edit(self, result: str | None) -> None:
        if result is None:
            return
        key, _, val = result.partition("=")
        self._rows[self._cursor] = (key.strip(), val.strip())
        self._refresh_table()
        self.focus()

    def action_add_row(self) -> None:
        self._rows.append(("", ""))
        self._cursor = len(self._rows) - 1
        self._refresh_table()
        self.action_edit_row()

    def action_delete_row(self) -> None:
        if not self._rows:
            return
        self._rows.pop(self._cursor)
        if not self._rows:
            self._rows = [("", "")]
        self._cursor = min(self._cursor, len(self._rows) - 1)
        self._refresh_table()

    def get_data(self) -> dict[str, str]:
        """Return rows as dict, skipping blank keys."""
        result: dict[str, str] = {}
        for k, v in self._rows:
            k = k.strip()
            if k:
                result[k] = str(v).strip()
        return result



class EditSecretModal(ModalScreen[dict | None]):
    CSS = """
    EditSecretModal {
        align: center middle;
    }
    #popup {
        width: 90%;
        max-width: 120;
        height: 98%;
        padding: 1 2;
        border: round #00d75f;
        background: black;
    }
    #popup_error {
        height: auto;
        margin: 0;
    }
    #popup_busy {
        height: auto;
        margin: 0 0 0 0;
        color: #00d7ff;
    }
    .field_error {
        height: auto;
        color: red;
        margin: 0;
    }
    #token_toggle_hint {
        height: auto;
        color: #777777;
        margin-top: 0;
    }
    #token_generate_hint {
        height: auto;
        color: #777777;
        margin-top: 0;
    }
    Input {
        width: 100%;
        border: round #444444;
        padding: 0 1;
    }
    Input:focus {
        border: round cyan;
    }
    #popup_scroll {
        height: 1fr;
        min-height: 0;
        overflow-y: auto;
        margin-top: 1;
    }
    .popup_panel {
        margin-top: 1;
    }
    #popup_form {
        margin-top: 1;
        padding: 1 1 2 1;
        border: round #444444;
        background: #111111;
        height: auto;
    }
    .field_label {
        margin-top: 1;
        color: #aaaaaa;
    }
    #popup_hint {
        margin-top: 1;
        height: auto;
        color: #aaaaaa;
    }
    #popup_title_panel {
        height: auto;
    }
    """

    BINDINGS = [
        ("escape", "cancel", "Cancel"),
        ("up", "prev_field", "Prev field"),
        ("k", "prev_field", "Prev field"),
        ("down", "next_field", "Next field"),
        ("j", "next_field", "Next field"),
        ("tab", "next_field", "Next field"),
        ("shift+tab", "prev_field", "Prev field"),
        ("enter", "save", "Save"),
        ("ctrl+s", "save", "Save"),
        ("ctrl+t", "toggle_secret_visibility", "Show/hide secret"),
        ("ctrl+g", "generate_secret", "Generate secret"),
        ("ctrl+@", "make_default", "Flag as default"),
    ]

    def __init__(
        self,
        *,
        mode: str,
        service: str,
        api_url: str,
        name: str,
        known_service: KnownService | None,
        existing_token: str | None,
        instructions: list[str],
        auth: str | None,
        meta: dict | None,
        require_token: bool,
        is_default: bool = False,
        all_entries: list | None = None,
    ) -> None:
        super().__init__()
        self.mode = mode
        self.service = service
        self.api_url = api_url
        self.secret_name = name
        self.known_service = known_service
        self.existing_token = existing_token
        self.instructions = instructions
        self.auth = auth
        raw_meta: dict[str, object] = dict(meta or {})
        self.required_meta_keys = _required_metadata_keys(known_service)
        self._required_meta_ids = {
            key: f"required_meta_{re.sub(r'[^A-Za-z0-9_]+', '_', key)}"
            for key in self.required_meta_keys
        }
        self._required_meta_error_ids = {
            key: f"err_required_meta_{re.sub(r'[^A-Za-z0-9_]+', '_', key)}"
            for key in self.required_meta_keys
        }
        self.required_meta: dict[str, str] = {}
        self.meta: dict = {}
        for key, value in raw_meta.items():
            if key in self.required_meta_keys:
                if value is None:
                    self.required_meta[key] = ""
                else:
                    self.required_meta[key] = str(value).strip()
            else:
                self.meta[key] = value
        for key in self.required_meta_keys:
            self.required_meta.setdefault(key, "")
        self.require_token = require_token
        self.is_default = is_default
        self.all_entries: list = list(all_entries or [])
        self._error: str | None = None

    def compose(self) -> ComposeResult:
        title = "Edit Secret" if self.mode != "missing" else "Add Secret"
        _web_url = self.meta.get("web_url") or (self.known_service.web_url if self.known_service else None)
        label_line = f"{self.secret_name} ({_web_url})" if _web_url else self.secret_name

        help_text = "\n".join(self.instructions).strip() if self.instructions else ""

        with Vertical(id="popup"):
            yield Static("", id="popup_title_panel")

            if help_text:
                yield Static(
                    Panel.fit(
                        "\n".join(f"- {l}" for l in help_text.splitlines()),
                        title=f"How to manually get a token for {self.secret_name}",
                        border_style="blue",
                    ),
                    classes="popup_panel",
                )
            elif self.mode != "custom" and self.known_service is not None:
                yield Static(
                    Panel.fit(
                        "No instructions are configured for this service.",
                        title=f"How to manually get a token for {self.secret_name}",
                        border_style="blue",
                    ),
                    classes="popup_panel",
                )

            with FormScroll(id="popup_scroll"):
                with Vertical(id="popup_form"):
                    yield Static("Name", classes="field_label")
                    yield Input(placeholder="leave blank to use service name", id="name")
                    yield Static("", classes="field_error", id="err_name")
                    yield Static("Service", classes="field_label")
                    yield Input(placeholder="e.g. github", id="service")
                    yield Static("", classes="field_error", id="err_service")
                    yield Static("URL", classes="field_label", id="url_label")
                    yield Input(placeholder="e.g. https://host[:port] (API URL)", id="url")
                    yield Static("", classes="field_error", id="err_url")
                    yield Static("Authentication Type", classes="field_label")
                    yield Select(
                        [
                            ("bearer (default)", "bearer"),
                            ("basic (token used as password in username/password)", "basic"),
                            ("private-token (PRIVATE-TOKEN header, used by GitLab)", "private-token"),
                            ("none (not an authentication token)", "none"),
                        ],
                        id="auth",
                        allow_blank=False,
                        prompt="Select auth type",
                    )
                    for key in self.required_meta_keys:
                        yield Static(_metadata_label(key), classes="field_label")
                        yield Input(placeholder=f"{_metadata_label(key)} (required)", id=self._required_meta_ids[key])
                        yield Static("", classes="field_error", id=self._required_meta_error_ids[key])
                    yield Static("Secret", classes="field_label", id="secret_label")
                    yield Input(placeholder="leave blank to keep existing", password=True, id="secret")
                    yield Static("", classes="field_error", id="err_secret")
                    yield Static("Ctrl+T to show/hide secret", id="secret_toggle_hint")
                    yield Static("", id="secret_generate_hint")
                    yield Static("", id="popup_busy")
                    yield Static("", id="popup_error")
                    yield Static("Metadata  (+/Ctrl+N add  Del/Ctrl+D remove  Enter edit)", classes="field_label")
                    yield MetaTable(initial=self.meta, id="meta_table")

            yield Static("Enter/Ctrl+S to save • Ctrl+T show/hide secret • Ctrl+G generate secret • Esc to cancel", id="popup_hint")

    def on_mount(self) -> None:
        self._service_in = self.query_one("#service", Input)
        self._url_in = self.query_one("#url", Input)
        self._url_label = self.query_one("#url_label", Static)
        self._name_in = self.query_one("#name", Input)
        self._auth_in = self.query_one("#auth", Select)
        self._required_meta_inputs: dict[str, Input] = {
            key: self.query_one(f"#{self._required_meta_ids[key]}", Input)
            for key in self.required_meta_keys
        }
        self._meta_table = self.query_one("#meta_table", MetaTable)
        self._secret_in = self.query_one("#secret", Input)
        self._error_out = self.query_one("#popup_error", Static)
        self._field_errors: dict[str, Static] = {
            "name": self.query_one("#err_name", Static),
            "service": self.query_one("#err_service", Static),
            "url": self.query_one("#err_url", Static),
            "secret": self.query_one("#err_secret", Static),
        }
        self._field_widgets: dict[str, Widget] = {
            "name": self._name_in,
            "service": self._service_in,
            "url": self._url_in,
            "secret": self._secret_in,
        }
        for key in self.required_meta_keys:
            self._field_errors[key] = self.query_one(f"#{self._required_meta_error_ids[key]}", Static)
            self._field_widgets[key] = self._required_meta_inputs[key]
        self._busy_out = self.query_one("#popup_busy", Static)
        self._secret_label = self.query_one("#secret_label", Static)
        self._secret_toggle_hint = self.query_one("#secret_toggle_hint", Static)
        self._secret_generate_hint = self.query_one("#secret_generate_hint", Static)
        self._busy_timer = None
        self._busy_label = ""
        self._busy_frame = 0

        self._service_in.value = self.service
        self._url_in.value = self.api_url
        self._name_in.value = self.secret_name
        _auth_val = self.auth or "bearer"
        if _auth_val not in ("bearer", "basic", "private-token", "none"):
            _auth_val = "bearer"
        self._auth_in.value = _auth_val
        for key, widget in self._required_meta_inputs.items():
            widget.value = self.required_meta.get(key, "")
        self._update_secret_label()

        # Show notice if this entry is not the default and others exist for same URL.
        self._title_panel = self.query_one("#popup_title_panel", Static)
        self._update_default_notice()

        if self.mode in {"existing", "missing"}:
            self._service_in.disabled = True
            self._url_in.disabled = True

        self._base_token_placeholder = f"{self._secret_field_label()} (required)" if self.require_token else "leave blank to keep existing"
        self._secret_in.placeholder = self._base_token_placeholder

        self._secret_in.focus()
        self.call_after_refresh(self._scroll_to_field, self._secret_in)
        self._update_secret_toggle_hint()
        self._apply_secret_placeholder()
        self._update_secret_generate_hint()

    def _start_busy(self, label: str) -> None:
        self._busy_label = label
        self._busy_frame = 0
        self._busy_out.update(f"{label} |")
        self._busy_out.refresh()
        if self._busy_timer is not None:
            self._busy_timer.stop()
        self._busy_timer = self.set_interval(0.1, self._tick_busy)

    def _stop_busy(self) -> None:
        if self._busy_timer is not None:
            self._busy_timer.stop()
            self._busy_timer = None
        self._busy_out.update("")
        self._busy_out.refresh()
        self._busy_label = ""

    def _tick_busy(self) -> None:
        frames = ["|", "/", "-", "\\"]
        self._busy_frame = (self._busy_frame + 1) % len(frames)
        self._busy_out.update(f"{self._busy_label} {frames[self._busy_frame]}")
        self._busy_out.refresh()

    async def _flush_ui(self) -> None:
        """Wait for the next refresh so status/spinner updates become visible."""
        self._busy_out.refresh()
        self.app.refresh()
        # Yield control multiple times to let Textual fully process the refresh pipeline.
        await asyncio.sleep(0)
        await asyncio.sleep(0)
        await asyncio.sleep(0.1)

    async def on_input_submitted(self, event: Input.Submitted) -> None:  # type: ignore[name-defined]
        # Make Enter work as "Save" while focused on an input.
        await self.action_save()

    def on_key(self, event: events.Key) -> None:
        # Clear any previous error as soon as the user interacts again.
        if self._error:
            self._clear_error()
        # ctrl+space — make this entry the default
        if event.key in ("ctrl+@", "ctrl+at", "ctrl+space"):
            event.stop()
            self.action_make_default()
        # Treat up/down as field navigation across the form instead of letting
        # the scroll container consume those keys.
        if event.key in ("up", "down"):
            focused = self.app.focused
            if isinstance(focused, Input):
                event.stop()
                if event.key == "up":
                    self.action_prev_field()
                else:
                    self.action_next_field()
            elif isinstance(focused, Select) and not focused.expanded:
                event.stop()
                if event.key == "up":
                    self.action_prev_field()
                else:
                    self.action_next_field()

    def on_select_changed(self, event: Select.Changed) -> None:  # type: ignore[name-defined]
        if getattr(event.select, "id", None) == "auth":
            self._update_secret_label()

    def on_input_changed(self, event: Input.Changed) -> None:  # type: ignore[name-defined]
        # Clear errors on any edit (including paste operations).
        if self._error:
            self._clear_error()
        if getattr(event.input, "id", None) == "secret":
            self._apply_secret_placeholder()

    def _is_token_mode(self) -> bool:
        """Return True when auth type implies a bearer/header token (not 'none')."""
        val = getattr(self._auth_in, "value", None)
        return str(val or "").strip() not in ("none", "")

    def _secret_field_label(self) -> str:
        return "Token" if self._is_token_mode() else "Secret"

    def _update_secret_label(self) -> None:
        label = self._secret_field_label()
        none_mode = not self._is_token_mode()
        self._secret_label.update(label)
        self._base_token_placeholder = (
            f"{label} (required)" if self.require_token else "leave blank to keep existing"
        )
        self._apply_secret_placeholder()
        self._update_secret_toggle_hint()
        self._update_secret_generate_hint()

        # Hide/show URL field based on auth mode, round-tripping value via metadata
        if none_mode:
            # Moving to none: stash URL in meta if not already there
            url_val = self._url_in.value.strip()
            if url_val:
                self._url_in.value = ""
                def _stash_url(url_val=url_val):
                    if "api_url" not in self._meta_table.get_data():
                        if self._meta_table._rows == [("", "")]:
                            self._meta_table._rows = [("api_url", url_val)]
                        else:
                            self._meta_table._rows.append(("api_url", url_val))
                        self._meta_table._refresh_table()
                self.call_after_refresh(_stash_url)
        else:
            # Moving away from none: restore URL from meta if present
            meta_data = self._meta_table.get_data()
            if "api_url" in meta_data and not self._url_in.value.strip():
                restored = meta_data["api_url"]
                self._url_in.value = restored
                # Remove api_url row from meta table
                self._meta_table._rows = [
                    (k, v) for k, v in self._meta_table._rows if k.strip() != "api_url"
                ]
                if not self._meta_table._rows:
                    self._meta_table._rows = [("", "")]
                self._meta_table._refresh_table()
        self._url_label.display = not none_mode
        self._url_in.display = not none_mode

        hint = (
            f"Enter/Ctrl+S to save • Ctrl+T show/hide {label.lower()} • "
            f"Ctrl+G generate {label.lower()} • Esc to cancel"
        )
        try:
            self.query_one("#popup_hint", Static).update(hint)
        except Exception:
            pass

    def _update_secret_toggle_hint(self) -> None:
        shown = not getattr(self._secret_in, "password", True)
        label = self._secret_field_label().lower()
        self._secret_toggle_hint.update(f"Ctrl+T to hide {label}" if shown else f"Ctrl+T to show {label}")

    def _update_secret_generate_hint(self) -> None:
        if self.known_service and self.known_service.generate:
            label = self._secret_field_label().lower()
            self._secret_generate_hint.update(f"Ctrl+G to generate a new {label} (prompts for user/password)")
        else:
            self._secret_generate_hint.update("")

    def _apply_secret_placeholder(self) -> None:
        """Update the token placeholder based on visibility and whether the field is empty.

        If the user toggles to visible mode with an empty token field, show the existing
        token as a ghosted placeholder (explicit opt-in via Ctrl+T).
        """
        shown = not getattr(self._secret_in, "password", True)
        if shown and not self._secret_in.value and self.existing_token:
            self._secret_in.placeholder = self.existing_token
        else:
            self._secret_in.placeholder = self._base_token_placeholder

    def action_toggle_secret_visibility(self) -> None:
        # Only affects what the user has typed/pasted in this popup (we never pre-fill tokens).
        self._secret_in.password = not self._secret_in.password
        self._update_secret_toggle_hint()
        self._apply_secret_placeholder()

    def action_generate_secret(self) -> None:
        if not (self.known_service and self.known_service.generate):
            self._show_error("No secret generator configured for this service (TOML missing generate=...).")
            return
        cache = getattr(self.app, "basic_auth_passwords", None)
        if not isinstance(cache, dict):
            cache = {}
        self.app.push_screen(
            BasicAuthModal(
                title=f"Generate {self.secret_name} Secret",
                default_username=os.environ.get("USER") or "",
                password_cache=cache,
            ),
            self._on_basic_auth_result,
        )

    async def _on_basic_auth_result(self, result: dict | None) -> None:
        if not result:
            return
        username = str(result.get("username") or "").strip()
        password = str(result.get("password") or "")
        if not username or not password:
            self._show_error("Username and password are required to generate a token.")
            return
        assert self.known_service is not None
        self._start_busy("Generating token")
        await self._flush_ui()
        try:
            secret_val, msg = await asyncio.to_thread(_generate_token_known, self.known_service, username, password)
        finally:
            self._stop_busy()
        if not secret_val:
            self._show_error(f"{self._secret_field_label()} generation failed: {msg}")
            return
        # Put the new secret in the field (not saved until Enter).
        self._secret_in.value = secret_val
        self._secret_in.focus()
        self.call_after_refresh(self._scroll_to_field, self._secret_in)

    def _show_error(self, msg: str, field: str | None = None) -> None:
        self._error = msg
        if field and hasattr(self, "_field_errors") and field in self._field_errors:
            self._field_errors[field].update(f"[red]{msg}[/red]")
            target = getattr(self, "_field_widgets", {}).get(field)
            if target:
                # Two deferred refreshes: first lets the error text lay out,
                # second scrolls after the layout is stable
                def _do_scroll(w=target):
                    self.call_after_refresh(self._scroll_to_field, w)
                self.call_after_refresh(_do_scroll)
        else:
            self._error_out.update(Panel(f"[red]{msg}[/red]", title="Error", border_style="red"))

    def _clear_error(self) -> None:
        self._error = None
        self._error_out.update("")
        if hasattr(self, "_field_errors"):
            for w in self._field_errors.values():
                w.update("")
        try:
            self._name_in.styles.border = ("round", "#444444")
        except Exception:
            pass

    def _focusables(self) -> list:
        widgets = [
            self._name_in,
            self._service_in,
            self._url_in,
            self._auth_in,
            *[self._required_meta_inputs[key] for key in self.required_meta_keys],
            self._secret_in,
            self._meta_table,
        ]
        return [w for w in widgets if not getattr(w, "disabled", False) and getattr(w, "display", True)]

    def _focus_field(self, widget) -> None:
        widget.focus()
        self.call_after_refresh(self._scroll_to_field, widget)

    def _scroll_to_field(self, widget) -> None:
        try:
            scroll = self.query_one("#popup_scroll")
        except Exception:
            return
        focusables = self._focusables()
        if focusables and widget is focusables[0]:
            scroll.scroll_home(animate=False)
            return
        if focusables and widget is focusables[-1]:
            scroll.scroll_end(animate=False)
            return
        region = _region_in_scroll(widget, scroll)
        if region is not None:
            scroll.scroll_to_region(region, spacing=Spacing(2, 0, 2, 0), animate=False)

    def _resolve_focused_field(self, focusables: list) -> int | None:
        """Return the index in focusables of the currently focused widget."""
        current = self.app.focused
        try:
            return focusables.index(current)
        except ValueError:
            pass
        return None

    def _render_title_panel(self) -> None:
        from rich.text import Text
        from rich.columns import Columns
        title = "Edit Secret" if self.mode != "missing" else "Add Secret"
        _web_url = self.meta.get("web_url") or (self.known_service.web_url if self.known_service else None)
        label_line = f"{self.secret_name} ({_web_url})" if _web_url else self.secret_name
        same_url_others = [
            e for e in self.all_entries
            if e.service == self.service and e.api_url == self.api_url
            and e.name != self.secret_name
        ]
        notice = ""
        if same_url_others and not self.is_default:
            notice = "[#ffaf00]Not default  •  Ctrl+Space to make default[/#ffaf00]"
        if notice:
            from rich.table import Table
            tbl = Table.grid(expand=True)
            tbl.add_column()
            tbl.add_column(justify="right")
            tbl.add_row(
                Panel.fit(f"[b]{title}[/b]\n{label_line}", border_style="bright_green"),
                notice,
            )
            self._title_panel.update(tbl)
        else:
            self._title_panel.update(
                Panel.fit(f"[b]{title}[/b]\n{label_line}", border_style="bright_green")
            )

    def _update_default_notice(self) -> None:
        self._render_title_panel()

    def action_make_default(self) -> None:
        if self.is_default:
            return
        self.is_default = True
        self._update_default_notice()

    def _do_save(
        self,
        service: str,
        api_url: str,
        name: str,
        secret: str,
        fields: dict,
        is_default: bool,
        original_name: str | None = None,
    ) -> None:
        """Attempt to write the entry; show error in modal on failure, dismiss on success."""
        orig = original_name if original_name is not None else self.secret_name
        try:
            update_secret_file(
                service, api_url, name, secret, fields,
                original_name=orig,
                default=is_default,
            )
        except ValueError as exc:
            self._show_error(str(exc))
            return
        self.dismiss({"service": service, "api_url": api_url, "name": name})

    def action_prev_field(self) -> None:
        focusables = self._focusables()
        if not focusables:
            return
        i = self._resolve_focused_field(focusables)
        if i is None:
            self._focus_field(focusables[0])
            return
        self._focus_field(focusables[(i - 1) % len(focusables)])

    def action_next_field(self) -> None:
        focusables = self._focusables()
        if not focusables:
            return
        i = self._resolve_focused_field(focusables)
        if i is None:
            self._focus_field(focusables[0])
            return
        self._focus_field(focusables[(i + 1) % len(focusables)])

    def action_cancel(self) -> None:
        self.dismiss(None)

    async def action_save(self) -> None:
        self._clear_error()
        service = self._service_in.value.strip()
        api_url = self._url_in.value.strip()
        name = self._name_in.value.strip()
        auth_val = self._auth_in.value
        auth = "" if auth_val is getattr(Select, "BLANK", None) else str(auth_val or "")
        meta = self._meta_table.get_data()
        required_meta = {key: widget.value.strip() for key, widget in self._required_meta_inputs.items()}
        secret = self._secret_in.value.strip()
        is_default = self.is_default

        if not service:
            self._show_error("Service is required.", field="service")
            return
        if not api_url and self._is_token_mode():
            self._show_error("URL is required.", field="url")
            return
        if not name:
            name = service
        for key in self.required_meta_keys:
            if not required_meta.get(key):
                self._show_error(f"{_metadata_label(key)} is required.", field=key)
                return
        if self.require_token and not secret:
            self._show_error(f"{self._secret_field_label()} is required.", field="secret")
            return

        # Duplicate-name check: name must be unique within the service file.
        for entry in self.all_entries:
            if (
                entry.service == service
                and entry.name == name
                and entry.api_url != api_url
            ):
                self._show_error(f"Name {name!r} is already in use. Choose a different name.", field="name")
                self._focus_field(self._name_in)
                return

        # Fall back to existing stored secret if field left blank
        if not secret:
            secret = _read_existing_token(service, self.secret_name) or _read_existing_token(service, name) or ""
        if not secret and not self.require_token:
            pass  # allowed — no secret stored yet is fine for non-required
        elif not secret:
            self._show_error(f"{self._secret_field_label()} is required.", field="secret")
            return

        for key in self.required_meta_keys:
            meta.pop(key, None)
        save_fields: dict[str, object] = {"auth": auth or None}
        save_fields.update(required_meta)
        save_fields.update(meta)

        # Refresh expiry metadata from known service config when secret changed
        if secret and self.known_service and secret != (self.existing_token or ""):
            save_fields.pop("expires", None)
            save_fields.pop("expires_epoch", None)
            exp_meta, _ = _expires_metadata_from_known(self.known_service, secret)
            if exp_meta:
                save_fields.update(exp_meta)

        validate_fields = {k: str(v) for k, v in save_fields.items() if isinstance(v, (str, int)) and v not in ("", None)}

        if secret and self.known_service:
            self._start_busy(f"Validating {self._secret_field_label().lower()}")
            # Store pending save data so the callback can finish the dismiss.
            self._pending_save = {
                "service": service,
                "api_url": api_url,
                "name": name,
                "original_name": self.secret_name,
                "secret": secret,
                "fields": save_fields,
                "default": is_default,
            }

            def _do_validate() -> tuple[bool, str]:
                return _validate_token_known(self.known_service, secret, validate_fields)

            self.run_worker(_do_validate, thread=True, name="validate_token")
            # Don't await — return immediately so the event loop stays free for the spinner.
            return

        self._do_save(service, api_url, name, secret, save_fields, is_default)

    def on_worker_state_changed(self, event: Worker.StateChanged) -> None:
        """Called by Textual when a worker finishes — complete the save flow."""
        if event.worker.name != "validate_token":
            return
        from textual.worker import WorkerState
        if event.state not in (WorkerState.SUCCESS, WorkerState.ERROR, WorkerState.CANCELLED):
            return

        self._stop_busy()
        pending = getattr(self, "_pending_save", None)
        if pending is None:
            return

        if event.state == WorkerState.ERROR:
            self._show_error(f"{self._secret_field_label()} validation error: {event.worker.error}")
            self._pending_save = None
            return

        if event.state == WorkerState.CANCELLED:
            self._pending_save = None
            return

        result = event.worker.result
        if result is not None:
            ok, msg = result
            if not ok:
                prefix = "Missing required metadata:"
                if msg.startswith(prefix):
                    key = msg[len(prefix):].strip()
                    if key in self._required_meta_inputs:
                        self._show_error(f"{_metadata_label(key)} is required.", field=key)
                        self._pending_save = None
                        return
                self._show_error(f"{self._secret_field_label()} validation failed: {msg}")
                self._pending_save = None
                return

        p = self._pending_save
        self._pending_save = None
        self._do_save(
            p["service"], p["api_url"], p["name"],
            p["secret"], p["fields"], p.get("default", False),
            original_name=p.get("original_name"),
        )



def _format_expires(expires_epoch, expires_str) -> str:
    """Format an expiry value as a human-readable date string."""
    if expires_str is not None and str(expires_str).strip().casefold() == "never":
        return "never"
    epoch: int | None = None
    if expires_epoch is not None:
        try:
            epoch = int(expires_epoch)
        except (ValueError, TypeError):
            pass
    if epoch is None and expires_str is not None:
        try:
            epoch = int(str(expires_str).strip())
        except (ValueError, TypeError):
            pass
    if epoch is not None:
        try:
            exp_dt = datetime.fromtimestamp(epoch, tz=timezone.utc).astimezone()
            now = datetime.now(tz=timezone.utc)
            days_left = (exp_dt - now).days
            date_str = exp_dt.strftime("%Y-%m-%d")
            if days_left < 0:
                return f"{date_str} (expired)"
            elif days_left <= 14:
                return f"{date_str} ({days_left}d left)"
            else:
                return date_str
        except Exception:
            return str(epoch)
    if expires_str:
        return str(expires_str)
    return "-"


class ConfirmDeleteModal(ModalScreen[bool]):
    """Simple yes/no confirmation for deleting a secret entry."""

    CSS = """
    ConfirmDeleteModal {
        align: center middle;
    }
    #confirm_popup {
        width: 60%;
        max-width: 80;
        height: auto;
        padding: 1 2;
        border: round red;
        background: black;
    }
    #confirm_msg {
        height: auto;
        margin-bottom: 1;
    }
    #confirm_hint {
        height: auto;
        color: #aaaaaa;
        margin-top: 1;
    }
    """

    BINDINGS = [
        ("y", "confirm", "Yes"),
        ("n", "cancel", "No"),
        ("enter", "confirm", "Yes"),
        ("escape", "cancel", "No"),
    ]

    def __init__(self, service: str, name: str) -> None:
        super().__init__()
        self._service = service
        self._name = name

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm_popup"):
            yield Static(
                f"Delete [cyan]{self._name}[/cyan] ([white]{self._service}[/white])?",
                id="confirm_msg",
            )
            yield Static("Y / Enter to confirm  •  N / Esc to cancel", id="confirm_hint")

    def on_mount(self) -> None:
        self.query_one("#confirm_popup").focus()

    def action_confirm(self) -> None:
        self.dismiss(True)

    def action_cancel(self) -> None:
        self.dismiss(False)


class ServiceSelector(App):
    """Textual UI that renders Rich tables and allows htop-like selection."""

    CSS = """
    #header {
        height: auto;
        dock: top;
    }
    #hint {
        height: auto;
        dock: bottom;
        margin-top: 1;
    }
    #root_scroll {
        height: 1fr;
        padding: 0 2;
    }
    #existing {
        height: auto;
    }
    #known {
        height: auto;
        margin-top: 1;
    }
    #custom {
        height: auto;
        margin-top: 1;
    }
    """

    BINDINGS = [
        ("q", "quit", "Quit"),
        ("up", "up", "Up"),
        ("down", "down", "Down"),
        ("k", "up", "Up"),
        ("j", "down", "Down"),
        ("enter", "edit", "Edit"),
        ("delete,backspace", "delete_entry", "Delete"),
    ]

    def __init__(self, entries: list[SecretEntry], known_services: list[KnownService]) -> None:
        super().__init__()
        self.entries = sorted(entries, key=lambda e: (e.service.casefold(), (e.name or e.service).casefold()))
        self.known_services = sorted(known_services, key=lambda e: (e.service.casefold(), (e.name or e.service).casefold()))
        # In-memory cache (per run) so repeated generation prompts can reuse passwords.
        self.basic_auth_passwords: dict[str, str] = {}
        # selection across: My Secrets + Known Services + Custom Service
        self._sel = 0
        self._status: str | None = None
        self._terminal_warning = _terminal_rendering_warning()

    def compose(self) -> ComposeResult:
        yield Static(id="header")
        with FormScroll(id="root_scroll"):
            yield Static(id="existing")
            yield Static(id="known")
            yield Static(id="custom")
        yield Static(id="hint")

    def on_mount(self) -> None:
        self._sel = 0
        self._refresh()

    def on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button == 2:
            event.stop()
            self._paste_primary_selection()

    def _paste_primary_selection(self) -> None:
        focused = self.focused
        if focused is None:
            return
        try:
            import tkinter as tk
            root = tk.Tk()
            root.withdraw()
            try:
                text = root.selection_get(selection="PRIMARY")
            except tk.TclError:
                text = ""
            finally:
                root.destroy()
        except Exception:
            text = ""
        if text:
            from textual.events import Paste
            focused.post_message(Paste(text))

    def on_key(self, event: events.Key) -> None:
        # Tab is often reserved for focus navigation in TUI frameworks / terminals.
        # Handle it explicitly to switch between the three tables.
        #
        # IMPORTANT: don't steal Tab from modal popups; they use Tab to move between fields.
        if isinstance(self.screen, ModalScreen):
            return
        if event.key == "tab":
            event.prevent_default()
            event.stop()
            self.action_next_table()
            return
        if event.key in {"shift+tab", "backtab"}:
            event.prevent_default()
            event.stop()
            self.action_prev_table()
            return

    def _n_items(self) -> int:
        return len(self.entries) + len(self.known_services) + 1

    def _section_of_sel(self) -> str:
        if self._sel < len(self.entries):
            return "existing"
        if self._sel < len(self.entries) + len(self.known_services):
            return "known"
        return "custom"

    def _section_start_index(self, name: str) -> int | None:
        if name == "existing":
            return 0 if self.entries else None
        if name == "known":
            return len(self.entries) if self.known_services else None
        if name == "custom":
            return len(self.entries) + len(self.known_services)
        return None

    def _current_selection(self) -> tuple[str, object] | None:
        if self._sel < len(self.entries):
            return ("existing", self.entries[self._sel])
        idx = self._sel - len(self.entries)
        if idx < len(self.known_services):
            return ("known", self.known_services[idx])
        return ("custom", None)

    def _known_service_for(self, service: str, api_url: str) -> KnownService | None:
        for ep in self.known_services:
            if ep.service == service and ep.api_url == api_url:
                return ep
        return None

    def _reload(self) -> None:
        self.entries = sorted(
            load_secret_entries(),
            key=lambda e: (e.service.casefold(), (e.name or e.service).casefold()),
        )
        self.known_services = sorted(
            self.known_services,
            key=lambda e: (e.service.casefold(), (e.name or e.service).casefold()),
        )
        if self._n_items() > 0:
            self._sel = max(0, min(self._sel, self._n_items() - 1))
        else:
            self._sel = 0

    def _set_status(self, msg: str | None) -> None:
        self._status = msg

    def _entry_display(self, entry: SecretEntry) -> tuple[str, str, str]:
        auth = entry.auth or "unknown"
        expires = _format_expires(entry.meta.get("expires_epoch"), entry.meta.get("expires"))
        displayed_url = entry.meta.get("web_url") or entry.api_url or ""
        skip = {"expires", "expires_epoch", "web_url"}
        meta_parts = []
        for k, v in entry.meta.items():
            if k in skip:
                continue
            if k == "api_url" and v == displayed_url:
                continue
            meta_parts.append(f"{k}={v}")
        if entry.api_url and entry.api_url != displayed_url and "api_url" not in entry.meta:
            meta_parts.insert(0, f"api_url={entry.api_url}")
        meta = " ".join(meta_parts) if meta_parts else "—"
        return expires, auth, meta

    def _url_display(self, service: str, api_url: str, web_url: str | None) -> str:
        """Display URL: prefer web URL (entry or known); else show API URL; else '—'."""
        if web_url:
            return web_url
        known = self._known_service_for(service, api_url)
        if known and known.web_url:
            return known.web_url
        return api_url or "—"

    def _build_existing_table(self) -> Table:
        table = Table(box=box.SIMPLE_HEAVY)
        table.add_column("Name", style="cyan", no_wrap=True)
        table.add_column("Service", style="white", no_wrap=True)
        table.add_column("URL", style="green")
        table.add_column("Expires", style="yellow")
        table.add_column("Auth", style="magenta", no_wrap=True)
        table.add_column("Details", style="magenta")
        if not self.entries:
            table.add_row("—", "—", "No secrets found", "—", "—", "—")
            return table
        for i, entry in enumerate(self.entries):
            expires, auth, meta = self._entry_display(entry)
            url = self._url_display(entry.service, entry.api_url, entry.meta.get("web_url"))
            label_display = entry.name or entry.service
            style = "reverse" if self._sel == i else None
            table.add_row(label_display, entry.service, url, expires, auth, meta, style=style)
        return table

    def _build_known_table(self) -> Table:
        table = Table(box=box.SIMPLE_HEAVY)
        table.add_column("Name", style="cyan", no_wrap=True)
        table.add_column("Service", style="white", no_wrap=True)
        table.add_column("URL", style="green")
        table.add_column("Auth", style="magenta", no_wrap=True)
        if not self.known_services:
            table.add_row("—", "—", "No known services configured", "—")
            return table
        offset = len(self.entries)
        for j, known_service in enumerate(self.known_services):
            style = "reverse" if self._sel == offset + j else None
            url = known_service.web_url or known_service.api_url
            auth = _default_auth_for_known(known_service)
            table.add_row(known_service.name, known_service.service, url, auth, style=style)
        return table

    def _build_custom_view(self) -> str:
        row_index = len(self.entries) + len(self.known_services)
        selected = self._sel == row_index
        head = "[b]Press Enter to add a custom service[/b]"
        if selected:
            head = f"[reverse]{head}[/reverse]"
        return head

    def _refresh(self) -> None:
        from rich.panel import Panel

        cur = self._section_of_sel()
        border_dim = "#00b37a"
        border_sel = "bright_green"

        self.query_one("#header", Static).update(
            Panel.fit("Secrets Manager", subtitle=_format_path_for_ui(SECRETS_DIR), border_style="bright_green")
        )
        self.query_one("#existing", Static).update(
            Panel(
                self._build_existing_table(),
                title="My Secrets",
                border_style=(border_sel if cur == "existing" else border_dim),
                padding=(0, 1),
            )
        )
        self.query_one("#known", Static).update(
            Panel(
                self._build_known_table(),
                title="Known Services",
                border_style=(border_sel if cur == "known" else border_dim),
                padding=(0, 1),
            )
        )
        self.query_one("#custom", Static).update(
            Panel(
                self._build_custom_view(),
                title="Custom Service",
                border_style=(border_sel if cur == "custom" else border_dim),
                padding=(0, 1),
            )
        )
        hint_lines = ["↑/↓ to select  •  Tab/Shift+Tab switch section  •  Enter to edit/add  •  Del to delete  •  q to quit"]
        if self._terminal_warning:
            hint_lines.append(f"[yellow]{self._terminal_warning}[/yellow]")
        if self._status:
            if self._status.startswith("Error:") or self._status.startswith("error:"):
                hint_lines.append(f"[red]{self._status}[/red]")
            else:
                hint_lines.append(self._status)
        self.query_one("#hint", Static).update("\n".join(hint_lines))
        self.call_after_refresh(self._scroll_to_selection)

    def _scroll_to_selection(self) -> None:
        try:
            scroll = self.query_one("#root_scroll")
        except Exception:
            return
        n = self._n_items()
        if n <= 0:
            return
        # Snap to absolute top or bottom when at the first or last item.
        if self._sel == 0:
            scroll.scroll_home(animate=False)
            return
        if self._sel == n - 1:
            scroll.scroll_end(animate=False)
            return
        section = self._section_of_sel()
        widget_id = {"existing": "#existing", "known": "#known", "custom": "#custom"}[section]
        try:
            section_widget = self.query_one(widget_id)
        except Exception:
            return
        region = _region_in_scroll(section_widget, scroll)
        if region is not None:
            scroll.scroll_to_region(region, spacing=Spacing(2, 0, 2, 0), animate=False)

    def action_up(self) -> None:
        n = self._n_items()
        if n <= 0:
            return
        self._sel = (self._sel - 1) % n
        self._refresh()

    def action_down(self) -> None:
        n = self._n_items()
        if n <= 0:
            return
        self._sel = (self._sel + 1) % n
        self._refresh()

    def action_next_table(self) -> None:
        order = ["existing", "known", "custom"]
        cur = self._section_of_sel()
        start = order.index(cur)
        for i in range(1, len(order) + 1):
            nxt = order[(start + i) % len(order)]
            idx = self._section_start_index(nxt)
            if idx is not None:
                self._sel = idx
                self._refresh()
                return

    def action_prev_table(self) -> None:
        order = ["existing", "known", "custom"]
        cur = self._section_of_sel()
        start = order.index(cur)
        for i in range(1, len(order) + 1):
            prv = order[(start - i) % len(order)]
            idx = self._section_start_index(prv)
            if idx is not None:
                self._sel = idx
                self._refresh()
                return

    def action_edit(self) -> None:
        selection = self._current_selection()
        if not selection:
            return
        sel_type, payload = selection
        # Fix any pre-existing default violations before opening the modal
        if sel_type == "existing":
            _fix_defaults(payload.service)  # type: ignore[union-attr]
            self._reload()
        elif sel_type == "known":
            _fix_defaults(payload.service)  # type: ignore[union-attr]
            self._reload()
        if sel_type == "existing":
            entry: SecretEntry = payload  # type: ignore[assignment]
            known = self._known_service_for(entry.service, entry.api_url)
            self.push_screen(
                EditSecretModal(
                    mode="existing",
                    service=entry.service,
                    api_url=entry.api_url,
                    instructions=(known.instructions if known else []),
                    name=entry.name,
                    known_service=known,
                    existing_token=_read_existing_token(entry.service, entry.name),
                    auth=entry.auth,
                    meta=entry.meta,
                    require_token=False,
                    is_default=entry.default,
                    all_entries=self.entries,
                ),
                self._on_edit_result,
            )
            return

        if sel_type == "known":
            known_service: KnownService = payload  # type: ignore[assignment]
            defaults = _default_fields_for_known(known_service)
            init_meta: dict = {}
            if known_service.web_url:
                init_meta["web_url"] = known_service.web_url
            self.push_screen(
                EditSecretModal(
                    mode="missing",
                    service=known_service.service,
                    api_url=known_service.api_url,
                    instructions=known_service.instructions,
                    name=known_service.name,
                    known_service=known_service,
                    existing_token=None,
                    auth=defaults.get("auth"),  # type: ignore[arg-type]
                    meta=init_meta,
                    require_token=True,
                    all_entries=self.entries,
                ),
                self._on_edit_result,
            )
            return

        # custom
        self.push_screen(
            EditSecretModal(
                mode="custom",
                service="",
                api_url="",
                instructions=[],
                name="",
                known_service=None,
                existing_token=None,
                auth=None,
                meta=None,
                require_token=True,
                all_entries=self.entries,
            ),
            self._on_edit_result,
        )

    def _on_edit_result(self, result: dict | None) -> None:
        if not result:
            self._set_status(None)
            self._refresh()
            return
        service = str(result.get("service") or "").strip()
        name = str(result.get("name") or "").strip()
        self._reload()
        self._set_status(f"Saved {service} {name}")
        self._refresh()

    def action_quit(self) -> None:
        self.exit()

    def action_delete_entry(self) -> None:
        selection = self._current_selection()
        if not selection:
            return
        sel_type, payload = selection
        if sel_type != "existing":
            return
        entry: SecretEntry = payload  # type: ignore[assignment]
        self.push_screen(
            ConfirmDeleteModal(entry.service, entry.name),
            self._on_delete_confirmed,
        )

    def _on_delete_confirmed(self, confirmed: bool) -> None:
        if not confirmed:
            return
        selection = self._current_selection()
        if not selection or selection[0] != "existing":
            return
        entry: SecretEntry = selection[1]  # type: ignore[assignment]
        delete_secret_entry(entry.service, entry.name)
        self._reload()
        self._set_status(f"Deleted {entry.service} {entry.name}")
        self._refresh()


class BasicAuthModal(ModalScreen[dict | None]):
    CSS = """
    BasicAuthModal {
        align: center middle;
    }
    #auth_popup {
        width: 80%;
        max-width: 100;
        height: auto;
        padding: 1 2;
        border: round #00d75f;
        background: black;
    }
    #auth_error {
        height: auto;
        margin-top: 1;
    }
    Input {
        width: 100%;
        border: round #444444;
        padding: 0 1;
    }
    Input:focus {
        border: round cyan;
    }
    #auth_hint {
        margin-top: 1;
        height: auto;
        color: #aaaaaa;
    }
    #auth_toggle_hint {
        height: auto;
        color: #777777;
        margin-top: 0;
    }
    """

    BINDINGS = [
        ("escape", "cancel", "Cancel"),
        ("up", "prev_field", "Prev field"),
        ("k", "prev_field", "Prev field"),
        ("down", "next_field", "Next field"),
        ("j", "next_field", "Next field"),
        ("tab", "next_field", "Next field"),
        ("shift+tab", "prev_field", "Prev field"),
        ("enter", "submit", "Generate"),
        ("ctrl+t", "toggle_password_visibility", "Show/hide password"),
    ]

    def __init__(
        self,
        *,
        title: str,
        default_username: str | None = None,
        password_cache: dict[str, str] | None = None,
    ) -> None:
        super().__init__()
        self._title = title
        self._default_username = (default_username or "").strip() or None
        self._password_cache = password_cache if isinstance(password_cache, dict) else {}
        self._error: str | None = None

    def compose(self) -> ComposeResult:
        with Vertical(id="auth_popup"):
            yield Static(Panel.fit(f"[b]{self._title}[/b]", border_style="bright_green"))
            yield Static("", id="auth_error")
            yield Static("Username", classes="field_label")
            if self._default_username:
                yield Input(placeholder=f"leave blank to use {self._default_username}", id="username")
            else:
                yield Input(placeholder="username", id="username")
            yield Static("Password", classes="field_label")
            yield Input(placeholder="password", password=True, id="password")
            yield Static("Ctrl+T to show password", id="auth_toggle_hint")
            yield Static("Enter to generate • Ctrl+T show/hide password • Esc to cancel", id="auth_hint")

    def on_mount(self) -> None:
        self._user_in = self.query_one("#username", Input)
        self._pass_in = self.query_one("#password", Input)
        self._err_out = self.query_one("#auth_error", Static)
        self._toggle_out = self.query_one("#auth_toggle_hint", Static)
        self._user_in.focus()
        self._update_toggle_hint()
        self._update_password_placeholder()

    def on_input_submitted(self, event: Input.Submitted) -> None:  # type: ignore[name-defined]
        # Make Enter work as "Generate" while focused on an input.
        self.action_submit()

    def _focusables(self) -> list[Input]:
        return [self._user_in, self._pass_in]

    def _do_save(
        self,
        service: str,
        api_url: str,
        name: str,
        secret: str,
        fields: dict,
        is_default: bool,
        original_name: str | None = None,
    ) -> None:
        """Attempt to write the entry; show error in modal on failure, dismiss on success."""
        orig = original_name if original_name is not None else self.secret_name
        try:
            update_secret_file(
                service, api_url, name, secret, fields,
                original_name=orig,
                default=is_default,
            )
        except ValueError as exc:
            self._show_error(str(exc))
            return
        self.dismiss({"service": service, "api_url": api_url, "name": name})

    def action_prev_field(self) -> None:
        focusables = self._focusables()
        current = self.app.focused
        try:
            i = focusables.index(current)  # type: ignore[arg-type]
        except ValueError:
            focusables[0].focus()
            return
        focusables[(i - 1) % len(focusables)].focus()

    def action_next_field(self) -> None:
        focusables = self._focusables()
        current = self.app.focused
        try:
            i = focusables.index(current)  # type: ignore[arg-type]
        except ValueError:
            focusables[0].focus()
            return
        focusables[(i + 1) % len(focusables)].focus()

    def on_input_changed(self, event: Input.Changed) -> None:  # type: ignore[name-defined]
        if self._error:
            self._error = None
            self._err_out.update("")
        if getattr(event.input, "id", None) == "username":
            self._update_password_placeholder()

    def _resolved_username(self) -> str:
        return self._user_in.value.strip() or (self._default_username or "")

    def _update_password_placeholder(self) -> None:
        username = self._resolved_username()
        if username and username in self._password_cache:
            self._pass_in.placeholder = "leave blank to use previous password"
        else:
            self._pass_in.placeholder = "password"

    def _update_toggle_hint(self) -> None:
        shown = not getattr(self._pass_in, "password", True)
        self._toggle_out.update("Ctrl+T to hide password" if shown else "Ctrl+T to show password")

    def action_toggle_password_visibility(self) -> None:
        self._pass_in.password = not self._pass_in.password
        self._update_toggle_hint()

    def action_cancel(self) -> None:
        self.dismiss(None)

    def action_submit(self) -> None:
        username = self._resolved_username()
        password = self._pass_in.value
        if username and not password and username in self._password_cache:
            password = self._password_cache[username]
        if not username or not password:
            self._error = "Username and password are required."
            self._err_out.update(Panel(f"[red]{self._error}[/red]", title="Error", border_style="red"))
            return
        # Cache the password for this username for subsequent prompts in this run.
        self._password_cache[username] = password
        self.dismiss({"username": username, "password": password})


def _resolve_secrets_dir(secrets_dir_arg: str | None) -> None:
    """Resolve and set SECRETS_DIR from CLI arg or config file."""
    global SECRETS_DIR
    toml_secrets_dir: str | None = None
    data = _load_manager_config()
    if data is not None:
        val = data.get("secrets_dir")
        if not isinstance(val, str) or not val.strip():
            val = data.get("pat_dir")
        if isinstance(val, str) and val.strip():
            toml_secrets_dir = val.strip()
    chosen = secrets_dir_arg or toml_secrets_dir
    if chosen:
        SECRETS_DIR = Path(os.path.expandvars(os.path.expanduser(chosen)))


def _resolve_known_services_path(config_arg: str | None) -> None:
    """Resolve the secrets manager config path from CLI arg or default."""
    global KNOWN_SERVICES_PATH, KNOWN_SERVICES_PATH_EXPLICIT
    if config_arg:
        KNOWN_SERVICES_PATH = Path(os.path.expandvars(os.path.expanduser(config_arg)))
        KNOWN_SERVICES_PATH_EXPLICIT = True
    else:
        KNOWN_SERVICES_PATH = KNOWN_SERVICES_PATH_DEFAULT
        KNOWN_SERVICES_PATH_EXPLICIT = False


def _resolve_known_services_include_test(include_test: bool) -> None:
    global KNOWN_SERVICES_INCLUDE_TEST
    KNOWN_SERVICES_INCLUDE_TEST = bool(include_test)


def _prompt_for_masked_value_from_io(stdin, stdout, prompt: str, empty_error: str) -> str:
    """Prompt interactively for a value while masking input with '*' characters."""
    if not stdin.isatty():
        raise ValueError("Interactive secret prompt requires a TTY.")
    try:
        fd = stdin.fileno()
    except Exception:
        raise ValueError("Interactive secret prompt requires a TTY.") from None

    stdout.write(prompt)
    stdout.flush()
    old_attrs = termios.tcgetattr(fd)
    chars: list[str] = []
    wrote_newline = False
    try:
        tty.setraw(fd)
        while True:
            ch = stdin.read(1)
            if ch in ("", "\x04"):
                raise EOFError
            if ch == "\x03":
                raise KeyboardInterrupt
            if ch in ("\r", "\n"):
                stdout.write("\r\n")
                stdout.flush()
                wrote_newline = True
                break
            if ch in ("\x7f", "\b"):
                if chars:
                    chars.pop()
                    stdout.write("\b \b")
                    stdout.flush()
                continue
            if ch.isprintable():
                chars.append(ch)
                stdout.write("*")
                stdout.flush()
    except (EOFError, KeyboardInterrupt):
        if not wrote_newline:
            stdout.write("\r\n")
            stdout.flush()
        raise ValueError("Secret entry cancelled.") from None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_attrs)
    secret = "".join(chars)
    if not secret:
        raise ValueError(empty_error)
    return secret


def _prompt_for_secret_value_from_io(stdin, stdout) -> str:
    return _prompt_for_masked_value_from_io(
        stdin,
        stdout,
        "Enter Secret Here: ",
        "Secret value is empty.",
    )


def _prompt_for_secret_value() -> str:
    """Prompt interactively for a secret without exposing it in argv or stdin."""
    return _prompt_for_secret_value_from_io(sys.stdin, sys.stdout)


def _prompt_for_sso_password() -> str:
    """Prompt interactively for an SSO password without exposing it in argv or stdin."""
    return _prompt_for_masked_value_from_io(
        sys.stdin,
        sys.stdout,
        "Enter SSO Password Here: ",
        "SSO password is empty.",
    )


def _prompt_generate_or_manual() -> str:
    if not sys.stdin.isatty():
        raise ValueError("Interactive selection requires a TTY.")
    prompt = (
        "Choose how to provide the token:\n"
        "  1. Generate token for me\n"
        "  2. Enter token manually\n"
        "Selection [1/2]: "
    )
    while True:
        try:
            sys.stdout.write(prompt)
            sys.stdout.flush()
            raw = sys.stdin.readline()
        except KeyboardInterrupt:
            sys.stdout.write("\n")
            sys.stdout.flush()
            raise ValueError("Selection cancelled.") from None
        if raw == "":
            raise ValueError("Selection cancelled.")
        choice = raw.strip().lower()
        if choice in {"1", "g", "generate"}:
            return "generate"
        if choice in {"2", "m", "manual"}:
            return "manual"
        sys.stdout.write("Please enter 1 for generate or 2 for manual.\n")
        sys.stdout.flush()


def _print_manual_token_instructions(known_service: "KnownService") -> None:
    instructions = [str(line).strip() for line in (known_service.instructions or []) if str(line).strip()]
    if not instructions:
        return
    sys.stdout.write(f"How to manually get a token for {known_service.name}:\n")
    for line in instructions:
        sys.stdout.write(f"  - {line}\n")
    sys.stdout.flush()


def build_service_selector(
    *,
    secrets_dir_arg: str | None = None,
    config_arg: str | None = None,
    include_test: bool = False,
    migrate_legacy: bool = True,
) -> ServiceSelector:
    """Build the Textual app with explicit path overrides for testing or embedding."""
    _resolve_known_services_path(config_arg)
    _resolve_known_services_include_test(include_test)
    _resolve_secrets_dir(secrets_dir_arg)

    if migrate_legacy and not SECRETS_DIR.exists() and LEGACY_PAT_DIR.exists():
        migrate_pat_dir(LEGACY_PAT_DIR, SECRETS_DIR)

    entries = load_secret_entries()
    known_services = load_known_services()
    return ServiceSelector(entries, known_services)


def main() -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Secrets Manager — store and retrieve service tokens and metadata.\n"
            "\n"
            "Without a subcommand, opens the interactive TUI.\n"
            "\n"
            "Secrets are stored in ~/.secrets/<service>.toml as named entries:\n"
            '  ["MyGitLab"]\n'
            "  api_url = \"https://gitlab.qualcomm.com\"\n"
            "  token   = \"glpat-...\"\n"
            "  auth    = \"private-token\"\n"
            "  default = true"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="For help on a subcommand: secrets <subcommand> -h  (e.g. secrets get -h  or  secrets set -h)",
    )
    parser.add_argument(
        "--secrets-dir",
        dest="secrets_dir",
        default=None,
        metavar="DIR",
        help="Override the secrets directory (default: ~/.secrets/).",
    )
    parser.add_argument(
        "--config",
        dest="config_path",
        default=None,
        metavar="FILE",
        help="Override the secrets manager TOML config (default: secrets_manager.toml next to the script).",
    )
    parser.add_argument(
        "--test",
        dest="include_test",
        action="store_true",
        help="Include known services and stored secrets with service name 'test' (hidden by default).",
    )

    subparsers = parser.add_subparsers(dest="command")

    # ── list ──────────────────────────────────────────────────────────────
    list_p = subparsers.add_parser(
        "list",
        help="List stored secrets.",
        description=(
            "Print a table of all stored secrets.\n"
            "\n"
            "Examples:\n"
            "  secrets list\n"
            "  secrets list --service gitlab\n"
            "  secrets list --json"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    list_p.add_argument("--service", default=None, metavar="NAME", help="Filter by service name (e.g. gitlab).")
    list_p.add_argument("--json", dest="as_json", action="store_true", help="Output as JSON array.")

    # ── get ───────────────────────────────────────────────────────────────
    get_p = subparsers.add_parser(
        "get",
        help="Retrieve a token or field value from a stored secret.",
        usage="secrets get <service> [-h] [--url URL] [--name NAME] [--extract FIELD] [--filter key=value] [--json]",
        description=(
            "Retrieve a value from a stored secret. Returns the token by default.\n"
            "\n"
            "Selection flags narrow which entry to use (AND logic).\n"
            "If multiple entries still match, the one marked default=true is used.\n"
            "\n"
            "Examples:\n"
            "  secrets get gitlab                              # secret\n"
            "  secrets get gitlab --extract auth              # auth type\n"
            "  secrets get gitlab --extract web_url           # browser URL\n"
            "  secrets get jira --url https://jira-dc3.qualcomm.com\n"
            "  secrets get test --name MyTest --extract token\n"
            "  secrets get test --filter auth=bearer --filter default=true\n"
            "  TOKEN=$(secrets get gitlab)"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    get_p.add_argument("service", help="Service name (e.g. gitlab, jira, splunk).")
    get_p.add_argument(
        "--url", "-u",
        default=None,
        metavar="URL",
        help="Select by URL — matches api_url or web_url (trailing slash ignored).",
    )
    get_p.add_argument(
        "--name", "-n",
        default=None,
        metavar="NAME",
        help="Select by exact secret name.",
    )
    get_p.add_argument(
        "--extract", "-e",
        default=None,
        metavar="FIELD",
        help=(
            "Field to return (default: token). "
            "Built-in: secret, auth, api_url, web_url, name, default, service. "
            "Any metadata key also works (e.g. email, expires)."
        ),
    )
    get_p.add_argument(
        "--filter", "-F",
        dest="filters",
        action="append",
        metavar="key=value",
        default=[],
        help=(
            "Select by exact field match (repeatable, AND logic). "
            "Keys: name, auth, api_url, web_url, default, or any metadata key."
        ),
    )
    get_p.add_argument("--json", dest="as_json", action="store_true", help="Wrap output in a JSON object.")

    # ── set ───────────────────────────────────────────────────────────────
    set_p = subparsers.add_parser(
        "set",
        help="Create or update a secret entry.",
        description=(
            "Create or update a secret entry.\n"
            "\n"
            "If an entry with the same service+name already exists it is updated.\n"
            "The command prompts interactively for the secret value, masks input with '*' characters,\n"
            "and avoids passing the secret via argv or stdin.\n"
            "If the matched known service supports generation, the CLI offers generate vs manual entry.\n"
            "Manual entry validates the token before saving.\n"
            "\n"
            "Examples:\n"
            "  secrets set jira --name 'Jira DC3' --api-url https://jira-dc3-tools.qualcomm.com --auth bearer\n"
            "  secrets set notes --name 'My Secret Note' --auth none"
        ),
        usage="secrets set <service> [-h] --name NAME [--api-url URL] [--auth AUTH] [--meta key=value] [--default]",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    set_p.add_argument("service", help="Service name (e.g. gitlab).")
    set_p.add_argument("--name", "-n", required=True, metavar="NAME", help="Secret name (required).")
    set_p.add_argument("--api-url", dest="api_url", default=None, metavar="URL", help="API URL for the service.")
    set_p.add_argument("--auth", default=None, metavar="AUTH", help="Auth type: bearer, basic, private-token, none.")
    set_p.add_argument(
        "--meta", "-m",
        dest="meta",
        action="append",
        metavar="key=value",
        default=[],
        help="Metadata field (repeatable). E.g. --meta web_url=https://gitlab.com",
    )
    set_p.add_argument("--default", dest="is_default", action="store_true", help="Mark as default for this URL.")
    set_p.add_argument("--json", dest="as_json", action="store_true", help="Print the saved entry as JSON.")

    args = parser.parse_args()

    _resolve_known_services_path(args.config_path)
    _resolve_known_services_include_test(args.include_test)
    _resolve_secrets_dir(args.secrets_dir)

    # Auto-migrate legacy ~/.PAT on first run.
    if not SECRETS_DIR.exists() and LEGACY_PAT_DIR.exists():
        migrate_pat_dir(LEGACY_PAT_DIR, SECRETS_DIR)

    # ── subcommand: list ──────────────────────────────────────────────────
    if args.command == "list":
        entries = load_secret_entries()
        if args.service:
            entries = [e for e in entries if e.service == args.service]
        if args.as_json:
            import json as _json
            out = []
            for e in entries:
                rec: dict = {"service": e.service, "name": e.name, "api_url": e.api_url, "auth": e.auth, "default": e.default}
                rec.update(e.meta)
                out.append(rec)
            print(_json.dumps(out, indent=2))
        else:
            console = Console()
            render_existing_table(console, entries)
        return 0

    # ── subcommand: get ───────────────────────────────────────────────────
    if args.command == "get":
        entries = load_secret_entries()
        matches = [e for e in entries if e.service == args.service]

        # Filter by --url (fuzzy: matches api_url or web_url, trailing-slash normalized)
        if args.url:
            query_url = args.url.rstrip("/")
            matches = [
                e for e in matches
                if e.api_url.rstrip("/") == query_url
                or (e.meta.get("web_url") or "").rstrip("/") == query_url
            ]

        # Filter by --name
        if args.name:
            matches = [e for e in matches if e.name == args.name]

        # Filter by --filter key=value (exact match, AND logic)
        active_filters: list[tuple[str, str]] = []
        for filt in (args.filters or []):
            if "=" not in filt:
                print(f"Invalid --filter {filt!r}: must be key=value", file=sys.stderr)
                return 1
            fkey, _, fval = filt.partition("=")
            fkey = fkey.strip()
            active_filters.append((fkey, fval))

        for fkey, fval in active_filters:
            if fkey == "name":
                matches = [e for e in matches if e.name == fval]
            elif fkey == "auth":
                matches = [e for e in matches if (e.auth or "") == fval]
            elif fkey == "api_url":
                matches = [e for e in matches if e.api_url == fval]
            elif fkey == "default":
                want = fval.lower() in ("true", "1", "yes")
                matches = [e for e in matches if e.default == want]
            else:
                matches = [e for e in matches if str(e.meta.get(fkey) or "") == fval]

        if not matches:
            filter_desc = []
            if args.url:
                filter_desc.append(f"url={args.url!r}")
            if args.name:
                filter_desc.append(f"name={args.name!r}")
            for fkey, fval in active_filters:
                filter_desc.append(f"{fkey}={fval!r}")
            print(f"No secret found for service={args.service!r} {' '.join(filter_desc)}", file=sys.stderr)
            return 1

        # Resolve multiple matches via default flag
        if len(matches) > 1:
            defaults = [e for e in matches if e.default]
            if len(defaults) == 1:
                matches = defaults
            elif len(defaults) > 1:
                names = ", ".join(e.name for e in defaults)
                print(f"Multiple defaults for service={args.service!r}: {names}", file=sys.stderr)
                print("Fix by ensuring only one entry has default = true for this URL.", file=sys.stderr)
                return 1
            else:
                names = ", ".join(e.name for e in matches)
                print(f"Multiple secrets match service={args.service!r}: {names}", file=sys.stderr)
                print("Use --name <name> or --filter to select one, or set default = true on the desired entry.", file=sys.stderr)
                return 1

        entry = matches[0]
        extract = args.extract or "secret"
        if extract == "secret":
            value = _read_existing_token(entry.service, entry.name) or ""
            if not value:
                print(f"No secret stored for {entry.service!r} {entry.name!r}", file=sys.stderr)
                return 1
        elif extract == "auth":
            value = entry.auth or ""
        elif extract == "api_url":
            value = entry.api_url
        elif extract == "web_url":
            value = entry.meta.get("web_url") or ""
        elif extract == "service":
            value = entry.service
        elif extract == "name":
            value = entry.name
        elif extract == "default":
            value = "true" if entry.default else "false"
        else:
            value = str(entry.meta.get(extract) or "")

        if args.as_json:
            import json as _json
            print(_json.dumps({extract: value}))
        else:
            print(value)
        return 0

    # ── subcommand: set ──────────────────────────────────────────────────
    if args.command == "set":
        # Parse --meta key=value pairs
        meta_fields: dict[str, object] = {}
        for m in (args.meta or []):
            if "=" not in m:
                print(f"Invalid --meta {m!r}: must be key=value", file=sys.stderr)
                return 1
            k, _, v = m.partition("=")
            meta_fields[k.strip()] = v

        # auth defaults to bearer if not specified
        if args.auth:
            meta_fields["auth"] = args.auth

        api_url = args.api_url or ""
        known_service = _known_service_by_key().get((args.service, api_url)) if api_url else None

        secret: str
        mode = "manual"
        if known_service is not None and known_service.generate:
            try:
                mode = _prompt_generate_or_manual()
            except ValueError as exc:
                print(f"Error: {exc}", file=sys.stderr)
                return 1

        if known_service is not None and mode == "generate":
                username = (os.environ.get("USER") or os.environ.get("LOGNAME") or "").strip()
                if not username:
                    print("Error: Cannot determine username for generator. Set USER or LOGNAME.", file=sys.stderr)
                    return 1
                try:
                    password = _prompt_for_sso_password()
                except ValueError as exc:
                    print(f"Error: {exc}", file=sys.stderr)
                    return 1
                print("Generating token...")
                secret, msg = _generate_token_known(known_service, username, password)
                if not secret:
                    print(f"Error: Token generation failed: {msg}", file=sys.stderr)
                    return 1
        else:
            if known_service is not None and known_service.generate and mode == "manual":
                _print_manual_token_instructions(known_service)
            try:
                secret = _prompt_for_secret_value()
            except ValueError as exc:
                print(f"Error: {exc}", file=sys.stderr)
                return 1
            if known_service is not None:
                validate_fields = {k: str(v) for k, v in meta_fields.items() if isinstance(v, (str, int)) and v not in ("", None)}
                print("Validating token...")
                is_valid, msg = _validate_token_known(known_service, secret, validate_fields)
                if not is_valid:
                    print(f"Error: Token is not valid: {msg}", file=sys.stderr)
                    print("Token will not be saved.", file=sys.stderr)
                    return 1

        if known_service is not None:
            exp_meta, _ = _expires_metadata_from_known(known_service, secret)
            if exp_meta:
                meta_fields.update(exp_meta)

        try:
            update_secret_file(
                service=args.service,
                api_url=api_url,
                name=args.name,
                secret=secret,
                fields=meta_fields,
                default=args.is_default,
            )
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1

        if args.as_json:
            import json as _json
            entries = load_secret_entries()
            matches = [e for e in entries if e.service == args.service and e.name == args.name]
            if matches:
                e = matches[0]
                rec: dict = {"service": e.service, "name": e.name, "api_url": e.api_url, "auth": e.auth, "default": e.default}
                rec.update(e.meta)
                print(_json.dumps(rec, indent=2))
        else:
            print(f"Saved {args.service} {args.name}")
        return 0

    # ── no subcommand: open TUI ───────────────────────────────────────────
    build_service_selector(
        secrets_dir_arg=args.secrets_dir,
        config_arg=args.config_path,
        include_test=args.include_test,
        migrate_legacy=False,
    ).run(mouse=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
