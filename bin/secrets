    from textual.worker import Worker
except ModuleNotFoundError as exc:
    raise SystemExit(
        f"Missing Python dependency '{exc.name}'. "
        "Ship the bundled venv/ with this tool or run build_venv.sh before installing it."
    ) from exc

SECRETS_DIR = Path.home() / ".secrets"
LEGACY_PAT_DIR = Path.home() / ".PAT"
KNOWN_SERVICES_PATH_DEFAULT = Path(__file__).with_name("secrets_manager.toml")
KNOWN_SERVICES_PATH = KNOWN_SERVICES_PATH_DEFAULT
KNOWN_SERVICES_PATH_EXPLICIT = False
KNOWN_SERVICES_INCLUDE_TEST = False


@dataclass(frozen=True)
class SecretEntry:
    service: str
    api_url: str
    name: str
    secret: str | None
    auth: str | None
    meta: dict  # arbitrary extra fields (web_url, email, expires, expires_epoch, …)
    default: bool = False


@dataclass(frozen=True)
class KnownService:
    service: str
    api_url: str
    name: str
    web_url: str | None
    instructions: list[str]
    validate: dict | None
    expires: dict | None
    generate: dict | None


_NON_METADATA_FIELD_NAMES = {"name", "service", "api_url", "url", "auth", "secret", "default"}
_VALID_AUTH_VALUES = {"bearer", "basic", "private-token", "none"}


def _required_metadata_keys(known_service: KnownService | None) -> list[str]:
    """Return deduplicated required metadata keys declared by validator requests."""
    if known_service is None:
        return []

    cfg = known_service.validate or {}
    if not isinstance(cfg, dict):
        return []

    reqs = cfg.get("requests") or []
    if isinstance(reqs, dict):
        reqs = [reqs]
    if not isinstance(reqs, list):
        return []

    ordered: list[str] = []
    seen: set[str] = set()
    for req in reqs:
        if not isinstance(req, dict):
            continue
        requires = req.get("requires") or []
        if isinstance(requires, str):
            requires = [requires]
        if not isinstance(requires, list):
            continue
        for key in requires:
            normalized = str(key).strip()
            if not normalized or normalized in seen or normalized in _NON_METADATA_FIELD_NAMES:
                continue
            seen.add(normalized)
            ordered.append(normalized)
    return ordered


def _metadata_label(key: str) -> str:
    text = re.sub(r"[_-]+", " ", key).strip()
    return text.title() if text else "Metadata"


def _known_service_by_key() -> dict[tuple[str, str], KnownService]:
    return {(ks.service, ks.api_url): ks for ks in load_known_services()}


def _normalize_auth_value(auth: object, service: str, api_url: str, known_by_key: dict[tuple[str, str], KnownService] | None = None) -> str | None:
    raw = str(auth or "").strip().lower()
    if raw in _VALID_AUTH_VALUES:
        return raw
    if raw in {"", "unknown"}:
        known = (known_by_key or {}).get((service, api_url))
        if known is not None:
            return _default_auth_for_known(known)
        return None
    known = (known_by_key or {}).get((service, api_url))
    if known is not None:
        return _default_auth_for_known(known)
    return None


def _terminal_color_count(term: str) -> int | None:
    try:
        fd = sys.__stdout__.fileno() if getattr(sys, "__stdout__", None) is not None else 1
        curses.setupterm(term=term, fd=fd)
        colors = curses.tigetnum("colors")
    except Exception:
        return None
    return colors if isinstance(colors, int) and colors >= 0 else None


def _terminal_rendering_warning(term: str | None = None, color_term: str | None = None) -> str | None:
    term = (term or os.environ.get("TERM") or "").strip().lower()
    color_term = (color_term or os.environ.get("COLORTERM") or "").strip().lower()
    if not term:
        return None

    recommended = "Best results: use xterm-256color in the terminal and tmux-256color inside tmux."

    if term in {"dumb", "unknown"}:
        return f"Terminal rendering may be limited with TERM={term}. {recommended}"
    if "256color" in term:
        return None

    colors = _terminal_color_count(term)
    if colors is not None and 0 <= colors < 256:
        return f"Terminal rendering may be limited with TERM={term} ({colors} colors). {recommended}"
    if term.startswith(("xterm", "screen", "tmux")) and "256color" not in term:
        return f"Terminal rendering may be limited with TERM={term}. {recommended}"
    if color_term in {"", "0", "false"} and term in {"xterm", "screen"}:
        return f"Terminal rendering may be limited with TERM={term}. {recommended}"
    return None


def _load_manager_config() -> dict | None:
    if not KNOWN_SERVICES_PATH.exists():
        if KNOWN_SERVICES_PATH_EXPLICIT:
            raise SystemExit(f"Config file not found: {KNOWN_SERVICES_PATH}")
        return None

    try:
        data = tomllib.loads(KNOWN_SERVICES_PATH.read_text(encoding="utf-8"))
    except Exception as exc:
        if KNOWN_SERVICES_PATH_EXPLICIT:
            raise SystemExit(f"Failed to parse config file {KNOWN_SERVICES_PATH}: {exc}")
        return None

    if not isinstance(data, dict):
        if KNOWN_SERVICES_PATH_EXPLICIT:
            raise SystemExit(f"Config file {KNOWN_SERVICES_PATH} must contain a TOML table.")
        return None
    return data


def _filter_known_services(services: list[KnownService]) -> list[KnownService]:
    if KNOWN_SERVICES_INCLUDE_TEST:
        return services
    return [svc for svc in services if svc.service != "test"]


def _include_service_name(service: str) -> bool:
    return KNOWN_SERVICES_INCLUDE_TEST or service != "test"


